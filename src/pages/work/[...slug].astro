---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import MainContent from '../../components/MainContent.astro';
import RelatedProjects from '../../components/RelatedProjects.astro';
import Tag from '../../components/Tag.astro';
import BackLink from '../../components/BackLink.astro';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const workEntries = await getCollection('work');
  return workEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry, allWork: workEntries },
  }));
}

const { entry, allWork } = Astro.props;
const { Content } = await entry.render();
---

<!-- Thin reading progress bar pinned to top of viewport -->
<div class="reading-progress" id="reading-progress" aria-hidden="true"></div>

<Layout
  title={`${entry.data.title} — Jeff Herrera`}
  description={entry.data.description}
  ogImage={entry.data.cover}
>
  <MainContent>
    <div class="page-inner">

      <BackLink href="/" label="Work" />

      <header class="work-header">
        <!-- work-title is intentionally a local <h1> — it uses different sizing
             and spacing from <PageTitle> (48px vs 56px, 60px top padding vs 112px) -->
        <h1 class="work-title" transition:name={`work-title-${entry.slug}`}>{entry.data.title}</h1>

        {(entry.data.role || entry.data.company || entry.data.year) && (
          <div class="work-meta">
            {entry.data.role && <span>{entry.data.role}</span>}
            {entry.data.company && <span>{entry.data.company}</span>}
            {entry.data.year && <span>{entry.data.year}</span>}
          </div>
        )}

        <p class="work-desc">{entry.data.description}</p>

        {entry.data.tags.length > 0 && (
          <div class="work-tags">
            {entry.data.tags.map((tag) => (
              <Tag label={tag} />
            ))}
          </div>
        )}
      </header>

      {entry.data.cover && (
        <div class="work-cover">
          <Image src={entry.data.cover} alt={entry.data.title} class="work-cover-img" width={760} height={480} transition:name={`work-cover-${entry.slug}`} />
        </div>
      )}

      <div class="work-body prose">
        <Content />
      </div>

      <RelatedProjects current={entry} allWork={allWork} />

    </div>
  </MainContent>
</Layout>

<style>
  /* ── Reading progress bar ───────────────────────────────────────────────── */
  .reading-progress {
    position: fixed;
    bottom: 0;
    left: 0;
    height: 2px;
    width: 0%;
    background: var(--color-orange-500);
    z-index: 1000;
    will-change: width;
    /* Slightly smooth so it doesn't feel jittery on scroll */
    transition: width 0.08s linear;
    transform-origin: left center;
  }

  @media (prefers-reduced-motion: reduce) {
    .reading-progress {
      transition: none;
    }
  }

  .page-inner {
    padding-top: 40px;
    /* max-width: 760px; */

  }

  .work-header {
    margin-bottom: 48px;
  }

  .work-title {
    font-family: var(--font-fragment);
    font-size: 48px;
    line-height: 1.1;
    letter-spacing: -1.44px;
    color: var(--color-orange-950);
    margin: 0 0 16px;
  }

  .work-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    font-family: var(--font-uncut);
    font-size: 13px;
    letter-spacing: -0.13px;
    color: var(--color-taupe-400);
    margin-bottom: 16px;
  }

  .work-desc {
    font-family: var(--font-uncut);
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.36px;
    line-height: 1.35;
    color: var(--color-orange-950);
    margin: 0 0 20px;
  }

  .work-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .work-cover {
    margin-bottom: 48px;
    border-radius: 6px;
    overflow: hidden;
    background: var(--color-taupe-300);
  }

  .work-cover-img {
    width: 100%;
    display: block;
  }

  .work-body {
    font-family: var(--font-uncut);
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-orange-950);
  }

  .work-body :global(h2) {
    font-family: var(--font-fragment);
    font-size: 28px;
    letter-spacing: -0.56px;
    color: var(--color-orange-950);
    margin: 40px 0 16px;
  }

  .work-body :global(p) {
    margin: 0 0 20px;
  }

  .work-body :global(a) {
    color: var(--color-orange-500);
    text-decoration: none;
  }

  .work-body :global(a:hover) {
    text-decoration: underline;
  }
</style>

<script>
  function initReadingProgress() {
    const bar = document.getElementById('reading-progress') as HTMLElement | null;
    if (!bar) return;

    const onScroll = () => {
      const scrollable = document.documentElement.scrollHeight - window.innerHeight;
      const pct = scrollable > 0 ? (window.scrollY / scrollable) * 100 : 0;
      bar.style.width = `${Math.min(100, pct)}%`;
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll(); // set initial value

    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', onScroll);
    }, { once: true });
  }

  initReadingProgress();
  document.addEventListener('astro:after-swap', initReadingProgress);
</script>
