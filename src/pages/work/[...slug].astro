---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const workEntries = await getCollection('work');
  return workEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---

<BaseLayout title={`${entry.data.title} - Jeff Herrera`} description={entry.data.description}>
  <article class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <a
      href="/"
      class="inline-flex items-center text-sm text-zinc-600 dark:text-zinc-400 hover:text-zinc-900 dark:hover:text-zinc-100 mb-8 transition-colors"
    >
      <svg class="w-4 h-4 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
      Back to work
    </a>

    <header class="mb-12">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        {entry.data.title}
      </h1>

      {(entry.data.role || entry.data.company || entry.data.year) && (
        <div class="flex flex-wrap gap-4 text-zinc-600 dark:text-zinc-400 mb-6">
          {entry.data.role && <span>{entry.data.role}</span>}
          {entry.data.company && <span>{entry.data.company}</span>}
          {entry.data.year && <span>{entry.data.year}</span>}
        </div>
      )}

      <p class="text-xl text-zinc-600 dark:text-zinc-400 mb-6">
        {entry.data.description}
      </p>

      {entry.data.tags.length > 0 && (
        <div class="flex flex-wrap gap-2">
          {entry.data.tags.map((tag) => (
            <span class="px-3 py-1 text-sm rounded-full bg-zinc-100 dark:bg-zinc-800 text-zinc-700 dark:text-zinc-300">
              {tag}
            </span>
          ))}
        </div>
      )}
    </header>

    {entry.data.cover && (
      <img
        src={entry.data.cover}
        alt={entry.data.title}
        class="rounded-lg w-full mb-12"
      />
    )}

    <div class="prose prose-zinc dark:prose-invert max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>
