---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import MainContent from '../../components/MainContent.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Tag from '../../components/Tag.astro';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const workEntries = await getCollection('work');
  const sorted = [...workEntries]
    .filter(e => e.data.publishedAt)
    .sort((a, b) => b.data.publishedAt!.valueOf() - a.data.publishedAt!.valueOf());
  return workEntries.map(entry => {
    const idx = sorted.findIndex(e => e.slug === entry.slug);
    const prevWork = idx < sorted.length - 1 ? sorted[idx + 1] : null;
    const nextWork = idx > 0 ? sorted[idx - 1] : null;
    return {
      params: { slug: entry.slug },
      props: { entry, prevWork, nextWork },
    };
  });
}

const { entry, prevWork, nextWork } = Astro.props;
const { Content } = await entry.render();

const workJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CreativeWork',
  name: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.publishedAt?.toISOString(),
  creator: { '@type': 'Person', name: 'Jeff Herrera' },
  url: new URL(`/work/${entry.slug}`, Astro.site).href,
};
---

<!-- Thin reading progress bar pinned to top of viewport -->
<div class="reading-progress" id="reading-progress" aria-hidden="true"></div>

<Layout
  title={`${entry.data.title} — Jeff Herrera`}
  description={entry.data.description}
  ogImage={`/og/work/${entry.slug}.png`}
  jsonLd={workJsonLd}
>
  <MainContent>
    <div class="page-inner">

      <Breadcrumb crumbs={[{ label: 'Work', href: '/' }, { label: entry.data.title }]} />

      <header class="work-header">
        <!-- work-title is intentionally a local <h1> — it uses different sizing
             and spacing from <PageTitle> (48px vs 56px, 60px top padding vs 112px) -->
        <h1 class="work-title" transition:name={`work-title-${entry.slug}`}>{entry.data.title}</h1>

        {(entry.data.role || entry.data.company || entry.data.year) && (
          <div class="work-meta">
            {entry.data.role && <span>{entry.data.role}</span>}
            {entry.data.company && <span>{entry.data.company}</span>}
            {entry.data.year && <span>{entry.data.year}</span>}
          </div>
        )}

        <p class="work-desc">{entry.data.description}</p>

        {entry.data.tags.length > 0 && (
          <div class="work-tags">
            {entry.data.tags.map((tag) => (
              <Tag label={tag} />
            ))}
          </div>
        )}
      </header>

      {entry.data.cover && (
        <div class="work-cover" transition:name={`work-cover-${entry.slug}`}>
          <Image src={entry.data.cover} alt={entry.data.title} class="work-cover-img" width={760} height={480} />
        </div>
      )}

      <div class="work-body prose">
        <Content />
      </div>

      {(prevWork || nextWork) && (
        <nav class="work-nav-strip" aria-label="More work">
          {prevWork && (
            <a
              href={`/work/${prevWork.slug}`}
              class="work-nav-item work-nav-item--prev"
              data-cursor-label="View Project"
            >
              <span class="work-nav-dir">← Previous</span>
              {prevWork.data.cover && (
                <Image
                  src={prevWork.data.cover}
                  alt={prevWork.data.title}
                  width={400}
                  height={250}
                  class="work-nav-cover"
                  loading="lazy"
                />
              )}
              <span class="work-nav-title">{prevWork.data.title}</span>
            </a>
          )}
          {nextWork && (
            <a
              href={`/work/${nextWork.slug}`}
              class="work-nav-item work-nav-item--next"
              data-cursor-label="View Project"
            >
              <span class="work-nav-dir">Next →</span>
              {nextWork.data.cover && (
                <Image
                  src={nextWork.data.cover}
                  alt={nextWork.data.title}
                  width={400}
                  height={250}
                  class="work-nav-cover"
                  loading="lazy"
                />
              )}
              <span class="work-nav-title">{nextWork.data.title}</span>
            </a>
          )}
        </nav>
      )}

    </div>
  </MainContent>
</Layout>

<style>
  /* ── Reading progress bar ───────────────────────────────────────────────── */
  .reading-progress {
    position: fixed;
    bottom: 0;
    left: 0;
    height: 2px;
    width: 0%;
    background: var(--color-orange-500);
    z-index: 1000;
    will-change: width;
    /* Slightly smooth so it doesn't feel jittery on scroll */
    transition: width 0.08s linear;
    transform-origin: left center;
  }

  @media (prefers-reduced-motion: reduce) {
    .reading-progress {
      transition: none;
    }
  }

  .page-inner {
    padding-top: 40px;
    /* max-width: 760px; */

  }

  .work-header {
    margin-bottom: 48px;
  }

  .work-title {
    font-family: var(--font-fragment);
    font-size: 48px;
    line-height: 1.1;
    letter-spacing: -1.44px;
    color: var(--color-orange-950);
    margin: 0 0 16px;
  }

  .work-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    font-family: var(--font-sans);
    font-size: 13px;
    color: var(--color-taupe-400);
    margin-bottom: 16px;
  }

  .work-desc {
    font-family: var(--font-sans);
    font-size: 18px;
    font-weight: 500;
    line-height: 1.35;
    color: var(--color-orange-950);
    margin: 0 0 20px;
  }

  .work-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .work-cover {
    margin-bottom: 48px;
    border-radius: 6px;
    overflow: hidden;
    background: var(--color-taupe-300);
  }

  .work-cover-img {
    width: 100%;
    display: block;
  }

  .work-body {
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-orange-950);
  }

  .work-body :global(h2) {
    font-family: var(--font-fragment);
    font-size: 28px;
    letter-spacing: -0.56px;
    color: var(--color-orange-950);
    margin: 40px 0 16px;
  }

  .work-body :global(p) {
    margin: 0 0 20px;
  }

  .work-body :global(a) {
    color: var(--color-orange-500);
    text-decoration: none;
  }

  .work-body :global(a:hover) {
    text-decoration: underline;
  }

  /* ── Prev / Next work strip ──────────────────────────────────────────────── */
  .work-nav-strip {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-top: 80px;
    padding-top: 40px;
    border-top: 1px solid var(--color-taupe-300);
  }

  .work-nav-item {
    text-decoration: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
    border-radius: 6px;
    overflow: hidden;
    background: transparent;
    transition: opacity 0.2s;
  }

  .work-nav-item:hover {
    opacity: 0.8;
  }

  .work-nav-cover {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-radius: 4px;
    display: block;
    background: var(--color-taupe-300);
  }

  .work-nav-item--next {
    align-items: flex-end;
    text-align: right;
  }

  .work-nav-dir {
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-taupe-400);
  }

  .work-nav-title {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 600;
    color: var(--color-orange-950);
  }

  @media (max-width: 1023px) {
    .work-nav-strip {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  function initReadingProgress() {
    const bar = document.getElementById('reading-progress') as HTMLElement | null;
    if (!bar) return;

    let hasReported50 = false;

    const onScroll = () => {
      const scrollable = document.documentElement.scrollHeight - window.innerHeight;
      const pct = scrollable > 0 ? (window.scrollY / scrollable) * 100 : 0;
      bar.style.width = `${Math.min(100, pct)}%`;

      if (!hasReported50 && pct >= 50) {
        hasReported50 = true;
        import('@vercel/analytics').then(({ track }) => {
          const slug = window.location.pathname.split('/').filter(Boolean).pop() ?? '';
          track('read_milestone', { slug, pct: 50 });
        }).catch(() => {});
      }
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll(); // set initial value

    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', onScroll);
    }, { once: true });
  }

  initReadingProgress();
  document.addEventListener('astro:after-swap', initReadingProgress);
</script>
