---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import MainContent from '../../components/MainContent.astro';
import RelatedProjects from '../../components/RelatedProjects.astro';
import Tag from '../../components/Tag.astro';
import BackLink from '../../components/BackLink.astro';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const workEntries = await getCollection('work');
  return workEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry, allWork: workEntries },
  }));
}

const { entry, allWork } = Astro.props;
const { Content } = await entry.render();
---

<Layout title={`${entry.data.title} — Jeff Herrera`} description={entry.data.description}>
  <MainContent>
    <div class="page-inner">

      <BackLink href="/" label="Work" />

      <header class="work-header">
        <!-- work-title is intentionally a local <h1> — it uses different sizing
             and spacing from <PageTitle> (48px vs 56px, 60px top padding vs 112px) -->
        <h1 class="work-title">{entry.data.title}</h1>

        {(entry.data.role || entry.data.company || entry.data.year) && (
          <div class="work-meta">
            {entry.data.role && <span>{entry.data.role}</span>}
            {entry.data.company && <span>{entry.data.company}</span>}
            {entry.data.year && <span>{entry.data.year}</span>}
          </div>
        )}

        <p class="work-desc">{entry.data.description}</p>

        {entry.data.tags.length > 0 && (
          <div class="work-tags">
            {entry.data.tags.map((tag) => (
              <Tag label={tag} />
            ))}
          </div>
        )}
      </header>

      {entry.data.cover && (
        <div class="work-cover">
          <Image src={entry.data.cover} alt={entry.data.title} class="work-cover-img" width={760} height={480} />
        </div>
      )}

      <div class="work-body prose">
        <Content />
      </div>

      <RelatedProjects current={entry} allWork={allWork} />

    </div>
  </MainContent>
</Layout>

<style>
  .page-inner {
    padding-top: 40px;
    /* max-width: 760px; */

  }

  .work-header {
    margin-bottom: 48px;
  }

  .work-title {
    font-family: var(--font-fragment);
    font-size: 48px;
    line-height: 1.1;
    letter-spacing: -1.44px;
    color: var(--color-orange-950);
    margin: 0 0 16px;
  }

  .work-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    font-family: var(--font-uncut);
    font-size: 13px;
    letter-spacing: -0.13px;
    color: var(--color-taupe-400);
    margin-bottom: 16px;
  }

  .work-desc {
    font-family: var(--font-uncut);
    font-size: 18px;
    font-weight: 500;
    letter-spacing: -0.36px;
    line-height: 1.35;
    color: var(--color-orange-950);
    margin: 0 0 20px;
  }

  .work-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .work-cover {
    margin-bottom: 48px;
    border-radius: 6px;
    overflow: hidden;
    background: var(--color-taupe-300);
  }

  .work-cover-img {
    width: 100%;
    display: block;
  }

  .work-body {
    font-family: var(--font-uncut);
    font-size: 16px;
    line-height: 1.6;
    color: var(--color-orange-950);
  }

  .work-body :global(h2) {
    font-family: var(--font-fragment);
    font-size: 28px;
    letter-spacing: -0.56px;
    color: var(--color-orange-950);
    margin: 40px 0 16px;
  }

  .work-body :global(p) {
    margin: 0 0 20px;
  }

  .work-body :global(a) {
    color: var(--color-orange-500);
    text-decoration: none;
  }

  .work-body :global(a:hover) {
    text-decoration: underline;
  }
</style>
