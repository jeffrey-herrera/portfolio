---
import Layout from '../layouts/Layout.astro';
import MainContent from '../components/MainContent.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const allWork = await getCollection('work');

const brandWork  = allWork.filter(w => w.data.tags.some(t => t.toLowerCase() === 'brand'));
const physicalWork = allWork.filter(w => w.data.tags.some(t => t.toLowerCase() === 'physical'));
const digitalWork  = allWork.filter(w => w.data.tags.some(t => t.toLowerCase() === 'digital'));

const categories = [
  { name: 'Brand',    items: brandWork,    index: '01' },
  { name: 'Physical', items: physicalWork, index: '02' },
  { name: 'Digital',  items: digitalWork,  index: '03' },
];

const totalProjects = allWork.length;
---

<Layout title="Work Grid Concept — Jeff Herrera">
  <MainContent>

    <!-- Section header -->
    <div class="index-header">
      <span class="index-header__label">Selected Work</span>
      <span class="index-header__count">{totalProjects} Projects</span>
    </div>

    <!-- Work categories -->
    <div class="work-index">
      {categories.map((category) => (
        <section class="category-section">

          <!-- Category rule -->
          <div class="category-rule">
            <span class="category-rule__name">{category.name}</span>
            <span class="category-rule__line" aria-hidden="true"></span>
            <span class="category-rule__num">{category.index}</span>
          </div>

          {category.items.length === 0 ? (
            <p class="empty-state">No {category.name} projects yet</p>
          ) : (
            <div class="category-projects">

              <!-- Featured project (first) — full width -->
              {category.items[0] && (
                <a href={`/work/${category.items[0].slug}`} class="project-featured">
                  <div class={`project-featured__image project-featured__image--${category.name.toLowerCase()}`}>
                    {category.items[0].data.cover
                      ? <Image src={category.items[0].data.cover} alt={category.items[0].data.title} class="project-img" width={800} height={500} />
                      : null
                    }
                    <span class="project-hover-overlay" aria-hidden="true"></span>
                  </div>
                  <div class="project-featured__meta">
                    <span class="project-featured__title">{category.items[0].data.title}</span>
                    <span class="project-featured__detail">
                      {category.name}{category.items[0].data.year ? ` · ${category.items[0].data.year}` : ''}
                    </span>
                  </div>
                </a>
              )}

              <!-- Secondary projects — 2-up grid -->
              {category.items.length > 1 && (
                <div class="projects-secondary">
                  {category.items.slice(1).map((item) => (
                    <a href={`/work/${item.slug}`} class="project-secondary">
                      <div class={`project-secondary__image project-secondary__image--${category.name.toLowerCase()}`}>
                        {item.data.cover
                          ? <Image src={item.data.cover} alt={item.data.title} class="project-img" width={400} height={300} />
                          : null
                        }
                        <span class="project-hover-overlay" aria-hidden="true"></span>
                      </div>
                      <div class="project-secondary__meta">
                        <span class="project-secondary__title">{item.data.title}</span>
                        <span class="project-secondary__detail">
                          {category.name}{item.data.year ? ` · ${item.data.year}` : ''}
                        </span>
                      </div>
                    </a>
                  ))}
                </div>
              )}

            </div>
          )}
        </section>
      ))}
    </div>

  </MainContent>
</Layout>

<style>

  /* ===== SECTION HEADER ===== */
  .index-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-top: 112px;
    padding-bottom: 56px;
  }

  .index-header__label {
    font-family: var(--font-uncut);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-taupe-400);
  }

  .index-header__count {
    font-family: var(--font-uncut);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-taupe-400);
  }

  /* ===== WORK INDEX ===== */
  .work-index {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding-bottom: 120px;
  }

  /* ===== CATEGORY SECTION ===== */
  .category-section {
    margin-top: 80px;
  }

  .category-section:first-child {
    margin-top: 0;
  }

  /* ===== CATEGORY RULE ===== */
  .category-rule {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: 32px;
  }

  .category-rule__name {
    font-family: var(--font-uncut);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-orange-950);
    flex-shrink: 0;
  }

  .category-rule__line {
    flex: 1;
    height: 1px;
    background: var(--color-taupe-300);
  }

  .category-rule__num {
    font-family: var(--font-uncut);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.08em;
    color: var(--color-taupe-400);
    flex-shrink: 0;
  }

  /* ===== CATEGORY PROJECTS ===== */
  .category-projects {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  /* ===== FEATURED PROJECT ===== */
  .project-featured {
    display: block;
    text-decoration: none;
  }

  .project-featured__image {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
  }

  /* Placeholder gradients per category */
  .project-featured__image--brand {
    background: linear-gradient(135deg,
      oklch(from var(--color-orange-900) l c h / 0.9) 0%,
      oklch(from var(--color-orange-500) l c h / 0.7) 40%,
      oklch(from var(--color-taupe-300) l c h / 1) 100%
    );
  }
  .project-featured__image--physical {
    background: linear-gradient(145deg,
      #2a1f1a 0%,
      #6b3e26 45%,
      #a0624a 100%
    );
  }
  .project-featured__image--digital {
    background: linear-gradient(135deg,
      #1a1f2e 0%,
      #2d3a5c 50%,
      #4a5a8a 100%
    );
  }

  .project-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .project-hover-overlay {
    position: absolute;
    inset: 0;
    background: var(--color-orange-500);
    opacity: 0;
    transition: opacity 0.3s ease;
    mix-blend-mode: multiply;
    pointer-events: none;
  }

  .project-featured:hover .project-img { transform: scale(1.025); }
  .project-featured:hover .project-hover-overlay { opacity: 0.15; }
  .project-featured:hover .project-featured__title { color: var(--color-orange-500); }

  .project-featured__meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-top: 16px;
    padding-bottom: 4px;
  }

  .project-featured__title {
    font-family: var(--font-fragment);
    font-size: 22px;
    font-weight: 400;
    letter-spacing: -0.3px;
    color: var(--color-orange-950);
    transition: color 0.2s ease;
    font-feature-settings: 'ss03' 1, 'ss04' 1, 'dlig' 1;
  }

  .project-featured__detail {
    font-family: var(--font-uncut);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-taupe-400);
    flex-shrink: 0;
    margin-left: 24px;
  }

  /* ===== SECONDARY PROJECTS ===== */
  .projects-secondary {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4px;
    margin-top: 4px;
  }

  .project-secondary {
    display: block;
    text-decoration: none;
  }

  .project-secondary__image {
    position: relative;
    width: 100%;
    aspect-ratio: 4 / 3;
    overflow: hidden;
  }

  .project-secondary__image--brand {
    background: linear-gradient(155deg,
      oklch(from var(--color-taupe-300) l c h / 1) 0%,
      oklch(from var(--color-orange-900) l c h / 0.5) 100%
    );
  }
  .project-secondary__image--physical {
    background: linear-gradient(155deg, #3d2b1f 0%, #7a5040 100%);
  }
  .project-secondary__image--digital {
    background: linear-gradient(155deg, #1e2535 0%, #3a4870 100%);
  }

  .project-secondary:hover .project-img { transform: scale(1.025); }
  .project-secondary:hover .project-hover-overlay { opacity: 0.15; }
  .project-secondary:hover .project-secondary__title { color: var(--color-orange-500); }

  .project-secondary__meta {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding-top: 12px;
    padding-bottom: 4px;
  }

  .project-secondary__title {
    font-family: var(--font-fragment);
    font-size: 18px;
    font-weight: 400;
    letter-spacing: -0.2px;
    color: var(--color-orange-950);
    transition: color 0.2s ease;
    font-feature-settings: 'ss03' 1, 'ss04' 1, 'dlig' 1;
  }

  .project-secondary__detail {
    font-family: var(--font-uncut);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-taupe-400);
    flex-shrink: 0;
    margin-left: 16px;
  }

  /* ===== EMPTY STATE ===== */
  .empty-state {
    font-family: var(--font-uncut);
    font-size: 14px;
    color: var(--color-taupe-400);
    padding: 48px 0;
    margin: 0;
  }

</style>
