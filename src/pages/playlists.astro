---
import Layout from '../layouts/Layout.astro';
import MainContent from '../components/MainContent.astro';
import PageTitle from '../components/PageTitle.astro';
---

<Layout title="Playlists — Jeff Herrera">
  <MainContent>
    <div class="page-inner">

      <PageTitle title="Playlists" />

      <p class="page-intro">Curated music for creative work.</p>

      <div class="playlists">
        <!-- Add playlist embeds or cards here -->
        <article class="playlist-card">
          <h2 class="playlist-name">Example Playlist</h2>
          <p class="playlist-desc">
            Add your playlists here — embed Spotify, YouTube, or create custom collections.
          </p>
        </article>
      </div>

    </div>
  </MainContent>
</Layout>

<style>
  .page-inner {
    max-width: 700px;
  }

  .page-intro {
    font-family: var(--font-fragment);
    font-size: 20px;
    line-height: 1.35;
    letter-spacing: -0.4px;
    color: var(--color-taupe-400);
    margin: 0 0 48px;
  }

  .playlists {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .playlist-card {
    background: white;
    border-radius: 6px;
    padding: 24px;
  }

  .playlist-name {
    font-family: var(--font-fragment);
    font-size: 20px;
    letter-spacing: -0.4px;
    color: var(--color-orange-950);
    margin: 0 0 8px;
  }

  .playlist-desc {
    font-family: var(--font-uncut);
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-taupe-400);
    margin: 0;
  }
</style>
