---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Playlists - Jeff Herrera">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="mb-16">
      <h1 class="text-4xl md:text-5xl font-bold mb-4">
        Playlists
      </h1>
      <p class="text-xl text-zinc-600 dark:text-zinc-400 max-w-2xl">
        Curated collections of music, inspiration, and more.
      </p>
    </div>

    <div class="space-y-8">
      <!-- Example playlist card -->
      <article class="border border-zinc-200 dark:border-zinc-800 rounded-lg p-6">
        <h2 class="text-2xl font-semibold mb-2">
          Example Playlist
        </h2>
        <p class="text-zinc-600 dark:text-zinc-400 mb-4">
          Add your playlists here. You could embed Spotify playlists, YouTube videos, or create custom collections.
        </p>
      </article>

      <!-- Add more playlists here or integrate with an API -->
    </div>
  </div>
</BaseLayout>
