---
import Layout from '../layouts/Layout.astro';
import MainContent from '../components/MainContent.astro';
import PageTitle from '../components/PageTitle.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { formatReadTime, getReadTimeMinutes } from '../utils/readTime';

const allThoughts = await getCollection('thoughts');
const sortedThoughts = allThoughts
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .map((thought) => ({
    ...thought,
    readTimeMinutes: getReadTimeMinutes(thought.body),
  }));
---

<Layout title="Thoughts — Jeff Herrera" description="Writing about design, creativity, and how I think about creative work.">
  <MainContent>

    <PageTitle title="Thoughts" subtitle="Writing about design, creativity, and creative work." />

    {sortedThoughts.length === 0 ? (
      <p class="empty-state">No posts yet. Add writing in <code>src/content/thoughts/</code></p>
    ) : (
      <div class="thoughts-grid">
        {sortedThoughts.map((thought) => (
          <a
            href={`/thoughts/${thought.slug}`}
            class="post-card"
            data-cursor-label={`Read (${formatReadTime(thought.readTimeMinutes)})`}
          >
            <div class={`post-cover${!thought.data.cover ? ' post-cover--placeholder' : ''}`}>
              {thought.data.cover && (
                <Image
                  src={thought.data.cover}
                  alt=""
                  aria-hidden="true"
                  width={600}
                  height={338}
                  class="post-cover-img"
                />
              )}
            </div>
            <div class="post-text">
              <h2 class="post-title">{thought.data.title}</h2>
              <p class="post-excerpt">{thought.data.description}</p>
            </div>
          </a>
        ))}
      </div>
    )}

  </MainContent>
</Layout>

<style>
  .empty-state {
    font-family: var(--font-uncut);
    font-size: 15px;
    color: var(--color-taupe-400);
    margin: 0;
  }

  .empty-state code {
    font-family: monospace;
    font-size: 13px;
    background: var(--color-white);
    padding: 2px 6px;
    border-radius: 3px;
  }

  /* ── Card grid ───────────────────────────────────────────────────────── */
  .thoughts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px 20px;
  }

  /* ── Portrait card ───────────────────────────────────────────────────── */
  .post-card {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding: 20px 20px 36px;
    background: var(--color-white);
    border-radius: 10px;
    text-decoration: none;
    position: relative;
    transition: background 0.2s;
  }

  /* Decorative cutout circles — cream discs that punch through the card */
  .post-card::before,
  .post-card::after {
    content: '';
    position: absolute;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-cream);
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    pointer-events: none;
  }

  .post-card::before {
    top: -20px;
  }

  .post-card::after {
    bottom: -20px;
  }

  /* ── Cover image ─────────────────────────────────────────────────────── */
  .post-cover {
    aspect-ratio: 16 / 9;
    background: var(--color-taupe-300);
  }

  .post-cover--placeholder {
    background: linear-gradient(135deg, var(--color-orange-500), var(--color-orange-300));
    border-radius: 2px;
  }

  .post-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    border-radius: 2px;
  }

  /* ── Text ─────────────────────────────────────────────────────────────── */
  .post-text {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .post-title {
    font-family: var(--font-uncut);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.44px;
    line-height: 1.2;
    color: var(--color-taupe-500);
    margin: 0;
    transition: color 0.2s;
    font-feature-settings: 'dlig' 1;
  }

  .post-excerpt {
    font-family: var(--font-uncut);
    font-size: 18px;
    font-weight: 400;
    letter-spacing: -0.18px;
    line-height: 1.4;
    color: var(--color-taupe-500);
    margin: 0;
    transition: color 0.2s;
    font-feature-settings: 'dlig' 1;
  }

  /* ── Hover — dark card variant (pointer devices only) ────────────────── */
  @media (hover: hover) {
    .post-card:hover {
      background: var(--color-orange-950);
    }

    .post-card:hover .post-title {
      color: var(--color-orange-50);
    }

    .post-card:hover .post-excerpt {
      color: var(--color-orange-500);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .post-card,
    .post-title,
    .post-excerpt {
      transition: none;
    }
  }

  /* ── Mobile ──────────────────────────────────────────────────────────── */
  @media (max-width: 1023px) {
    .thoughts-grid {
      grid-template-columns: 1fr;
    }

    .post-title {
      font-size: 18px;
    }

    .post-excerpt {
      font-size: 15px;
    }
  }
</style>

<script>
  function initCardExit() {
    document.querySelectorAll<HTMLElement>('.post-card').forEach(card => {
      card.addEventListener('click', () => {
        // Clear any previously tagged card
        document.querySelectorAll<HTMLElement>('.post-card').forEach(c => {
          c.style.viewTransitionName = '';
        });
        card.style.viewTransitionName = 'thought-card-active';
      });
    });
  }

  document.addEventListener('astro:page-load', initCardExit);
</script>

<style is:global>
  @keyframes thoughtCardExit {
    from { opacity: 1; transform: translateY(0); }
    to   { opacity: 0; transform: translateY(-20px); }
  }

  ::view-transition-old(thought-card-active) {
    animation: thoughtCardExit 0.4s cubic-bezier(0.25, 0, 0, 1) both;
  }

  /* No matching element on detail page — suppress phantom new snapshot */
  ::view-transition-new(thought-card-active) {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    ::view-transition-old(thought-card-active) {
      animation: none;
    }
  }
</style>
