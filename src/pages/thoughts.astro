---
import Layout from '../layouts/Layout.astro';
import MainContent from '../components/MainContent.astro';
import PageTitle from '../components/PageTitle.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { formatReadTime, getReadTimeMinutes } from '../utils/readTime';

// ── Wada Sanzo color palette (fetched from GitHub at build time) ───────────
// Deduplicated by bg color, sorted by hue for maximum visual variety across cards
const PALETTE = [{"id":16,"bg":"#740909","title":"#abf5ed","excerpt":"#abf5ed"},{"id":93,"bg":"#000000","title":"#a6e6db","excerpt":"#a6e6db"},{"id":58,"bg":"#681916","title":"#33ff7d","excerpt":"#33ff7d"},{"id":84,"bg":"#ffcfc4","title":"#0f261f","excerpt":"#0f261f"},{"id":79,"bg":"#651300","title":"#2dbc94","excerpt":"#2dbc94"},{"id":198,"bg":"#a93400","title":"#ffe600","excerpt":"#40c945"},{"id":46,"bg":"#ff5200","title":"#000000","excerpt":"#000000"},{"id":19,"bg":"#522000","title":"#7aff00","excerpt":"#7aff00"},{"id":2,"bg":"#ff8c00","title":"#0d2b52","excerpt":"#0d2b52"},{"id":4,"bg":"#c3a55c","title":"#3400a3","excerpt":"#3400a3"},{"id":50,"bg":"#ebd999","title":"#2d0060","excerpt":"#2d0060"},{"id":42,"bg":"#e0b81f","title":"#2619d1","excerpt":"#2619d1"},{"id":60,"bg":"#fff59e","title":"#0d2b52","excerpt":"#0d2b52"},{"id":22,"bg":"#ffff00","title":"#0024cc","excerpt":"#0024cc"},{"id":52,"bg":"#f5f5b8","title":"#000000","excerpt":"#000000"},{"id":168,"bg":"#f2ff26","title":"#003e83","excerpt":"#7e3075"},{"id":61,"bg":"#bdf226","title":"#340059","excerpt":"#340059"},{"id":83,"bg":"#bcd382","title":"#202d85","excerpt":"#202d85"},{"id":69,"bg":"#9cb29e","title":"#000000","excerpt":"#000000"},{"id":119,"bg":"#a6e6db","title":"#0d2b52","excerpt":"#0d2b52"},{"id":75,"bg":"#abf5ed","title":"#202d85","excerpt":"#202d85"},{"id":106,"bg":"#008aa1","title":"#06004f","excerpt":"#06004f"},{"id":56,"bg":"#bfabcc","title":"#2619d1","excerpt":"#2619d1"},{"id":346,"bg":"#b319ab","title":"#b5ffc2","excerpt":"#bdf226"},{"id":273,"bg":"#ffb3f0","title":"#6f0043","excerpt":"#9b5348"},{"id":59,"bg":"#ff5ec4","title":"#000000","excerpt":"#000000"},{"id":157,"bg":"#6f0043","title":"#d1bd19","excerpt":"#4f8fe6"},{"id":101,"bg":"#e6adcf","title":"#0024cc","excerpt":"#0024cc"},{"id":27,"bg":"#ffa6d9","title":"#1b3644","excerpt":"#1b3644"},{"id":63,"bg":"#5c2c45","title":"#29bdad","excerpt":"#29bdad"},{"id":261,"bg":"#a10045","title":"#fff59e","excerpt":"#80ffcc"},{"id":104,"bg":"#a10b2b","title":"#f5f5b8","excerpt":"#f5f5b8"},{"id":124,"bg":"#730f1f","title":"#e0b81f","excerpt":"#99b333"},{"id":25,"bg":"#c9303e","title":"#bfffe6","excerpt":"#bfffe6"},{"id":18,"bg":"#d1b0b3","title":"#2d0060","excerpt":"#2d0060"},{"id":6,"bg":"#ff616b","title":"#000831","excerpt":"#000831"}];

// ── Deterministic slug → palette index ────────────────────────────────────
function hashSlug(slug: string): number {
  let hash = 5381;
  for (let i = 0; i < slug.length; i++) {
    hash = ((hash << 5) + hash + slug.charCodeAt(i)) | 0;
  }
  return Math.abs(hash) % PALETTE.length;
}

// ── Hue distance (circular, 0–180) ────────────────────────────────────────
function hexToHue(hex: string): number {
  const r = parseInt(hex.slice(1, 3), 16) / 255;
  const g = parseInt(hex.slice(3, 5), 16) / 255;
  const b = parseInt(hex.slice(5, 7), 16) / 255;
  const max = Math.max(r, g, b), min = Math.min(r, g, b);
  if (max === min) return 0;
  const d = max - min;
  let h = max === r ? (g - b) / d + (g < b ? 6 : 0)
        : max === g ? (b - r) / d + 2
        : (r - g) / d + 4;
  return h * 60;
}

function hueDist(a: number, b: number): number {
  const d = Math.abs(a - b) % 360;
  return d > 180 ? 360 - d : d;
}

// ── Date formatter ─────────────────────────────────────────────────────────
function formatDate(date: Date): string {
  return date.toLocaleDateString('en-US', { month: '2-digit', day: '2-digit', year: '2-digit' });
}

const HUE_THRESHOLD = 45; // degrees — minimum hue distance between adjacent cards

const allThoughts = await getCollection('thoughts');
const sorted = allThoughts
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf())
  .map((thought) => ({ ...thought, readTimeMinutes: getReadTimeMinutes(thought.body) }));

// Assign palettes: start from slug hash, step forward if too close to previous card
const sortedThoughts: (typeof sorted[0] & { palette: typeof PALETTE[0] })[] = [];
for (const thought of sorted) {
  const i = sortedThoughts.length;
  const startIdx = hashSlug(thought.slug);
  let palette = PALETTE[startIdx];
  if (i > 0) {
    const prevHue = hexToHue(sortedThoughts[i - 1].palette.bg);
    for (let offset = 0; offset < PALETTE.length; offset++) {
      const candidate = PALETTE[(startIdx + offset) % PALETTE.length];
      if (hueDist(hexToHue(candidate.bg), prevHue) >= HUE_THRESHOLD) {
        palette = candidate;
        break;
      }
    }
  }
  sortedThoughts.push({ ...thought, palette });
}
---

<Layout title="Thoughts — Jeff Herrera" description="Writing about design, creativity, and how I think about creative work.">
  <MainContent>

    <PageTitle title="Thoughts" subtitle="Writing about design, creativity, and creative work." />

    {sortedThoughts.length === 0 ? (
      <p class="empty-state">No posts yet. Add writing in <code>src/content/thoughts/</code></p>
    ) : (
      <div class="thoughts-grid">
        {sortedThoughts.map((thought) => (
            <a
              href={`/thoughts/${thought.slug}`}
              class="post-card"
              data-cursor-label={`Read (${formatReadTime(thought.readTimeMinutes)})`}
              style={`--card-bg:${thought.palette.bg};--card-title:${thought.palette.title};--card-excerpt:${thought.palette.excerpt}`}
            >
              <div class={`post-cover${!thought.data.cover ? ' post-cover--placeholder' : ''}`}>
                {thought.data.cover && (
                  <Image
                    src={thought.data.cover}
                    alt=""
                    aria-hidden="true"
                    width={600}
                    height={338}
                    class="post-cover-img"
                    loading="eager"
                  />
                )}
              </div>
              <div class="post-text">
                <div class="post-info">
                  <h2 class="post-title">{thought.data.title}</h2>
                  <p class="post-excerpt">{thought.data.description}</p>
                </div>
                <div class="post-meta">
                  <span class="post-meta-item"><span class="post-meta-label">DATE</span>{formatDate(thought.data.publishedAt)}</span>
                  <span class="post-meta-item"><span class="post-meta-label">READ</span>{formatReadTime(thought.readTimeMinutes)}</span>
                </div>
              </div>
            </a>
        ))}
      </div>
    )}

  </MainContent>
</Layout>

<style>
  /* ── Card grid ───────────────────────────────────────────────────────── */
  .thoughts-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px 20px;
  }

  /* ── Base card ───────────────────────────────────────────────────────── */
  .post-card {
    text-decoration: none;
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--card-bg, white);
    transition: background-color 0.25s ease, transform 0.25s ease;
    border-radius: 4px 4px 0 0;
    overflow: hidden;
  }

  /* Perforated stamp edge along the bottom */
  .post-card::after {
    content: '';
    position: absolute;
    bottom: -12px;
    left: 0;
    right: 0;
    height: 24px;
    background: radial-gradient(circle, var(--color-cream) 12px, transparent 12px)
      center / 32px 24px repeat-x;
    pointer-events: none;
  }

  /* ── Cover image ─────────────────────────────────────────────────────── */
  .post-cover {
    aspect-ratio: 16 / 9;
    background: var(--color-taupe-300);
    overflow: hidden;
  }

  .post-cover--placeholder {
    background: linear-gradient(135deg, var(--color-orange-500) 0%, var(--color-orange-900) 100%);
  }

  .post-cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(1.01);
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* ── Text block ──────────────────────────────────────────────────────── */
  .post-text {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 8px;
    margin: 20px 20px 40px;
    padding-top: 20px;
    border-top: 1px dashed color-mix(in srgb, var(--card-title, var(--color-taupe-300)) 35%, transparent);
  }

  .post-title {
    font-family: var(--font-uncut);
    font-size: 22px;
    font-weight: 700;
    letter-spacing: -0.44px;
    line-height: 1.2;
    color: var(--card-title, var(--color-orange-950));
    margin: 0 0 5px;
    transition: color 0.25s ease;
  }

  .post-excerpt {
    font-family: var(--font-uncut);
    font-size: 16px;
    letter-spacing: -0.14px;
    line-height: 1.35;
    color: color-mix(in srgb, var(--card-excerpt, var(--color-taupe-400)) 80%, var(--card-bg, white));
    margin: 0;
    text-wrap: balance;
    transition: color 0.25s ease;
  }

  /* ── Receipt metadata row ────────────────────────────────────────────── */
  .post-meta {
    display: flex;
    justify-content: space-between;
    margin-top: 20px;
    padding-top: 8px;
    border-top: 1px dashed color-mix(in srgb, var(--card-title, var(--color-taupe-300)) 35%, transparent);
  }

  .post-meta-item {
    font-family: var(--font-uncut);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--card-title, var(--color-taupe-400)) 60%, var(--card-bg, white));
    display: flex;
    gap: 6px;
    align-items: center;
    transition: color 0.25s ease;
  }

  .post-meta-label {
    opacity: 0.5;
  }

  /* ── Hover ───────────────────────────────────────────────────────────── */
  @media (hover: hover) {
    .post-card:hover {
      background-color: var(--card-title, var(--color-orange-950));
      transform: translateY(-4px);
    }
    .post-card:hover .post-cover-img {
      transform: scale(1.05);
    }
    .post-card:hover .post-title {
      color: var(--card-bg, var(--color-orange-50));
    }
    .post-card:hover .post-excerpt {
      color: color-mix(in srgb, var(--card-bg, var(--color-orange-50)) 65%, var(--card-title, transparent));
    }
    .post-card:hover .post-meta-item {
      color: color-mix(in srgb, var(--card-bg, var(--color-orange-50)) 65%, var(--card-title, transparent));
    }
    .post-card:hover .post-text {
      border-top-color: color-mix(in srgb, var(--card-bg, white) 35%, transparent);
    }
    .post-card:hover .post-meta {
      border-top-color: color-mix(in srgb, var(--card-bg, white) 35%, transparent);
    }
  }

  /* ── Reduced motion ──────────────────────────────────────────────────── */
  @media (prefers-reduced-motion: reduce) {
    .post-card,
    .post-cover-img,
    .post-title,
    .post-excerpt {
      transition: none;
    }
  }

  /* ── Super Big ──────────────────────────────────────────────────────────── */
  @media (min-width: 1600px) {
    .thoughts-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  /* ── Tablet ──────────────────────────────────────────────────────────── */
  @media (max-width: 1023px) {
    .thoughts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  /* ── Mobile ──────────────────────────────────────────────────────────── */
  @media (max-width: 600px) {
    .thoughts-grid {
      grid-template-columns: 1fr;
    }

    .post-title {
      font-size: 20px;
    }
  }
</style>

<script>
  function initCardExit() {
    document.querySelectorAll<HTMLElement>('.post-card').forEach(card => {
      card.addEventListener('click', () => {
        // Clear any previously tagged card
        document.querySelectorAll<HTMLElement>('.post-card').forEach(c => {
          c.style.viewTransitionName = '';
        });
        card.style.viewTransitionName = 'thought-card-active';
      });
    });
  }

  document.addEventListener('astro:page-load', initCardExit);
</script>

<style is:global>
  @keyframes thoughtCardExit {
    from { opacity: 1; transform: translateY(0); }
    to   { opacity: 0; transform: translateY(-20px); }
  }

  ::view-transition-old(thought-card-active) {
    animation: thoughtCardExit 0.4s cubic-bezier(0.25, 0, 0, 1) both;
  }

  /* No matching element on detail page — suppress phantom new snapshot */
  ::view-transition-new(thought-card-active) {
    display: none;
  }

  @media (prefers-reduced-motion: reduce) {
    ::view-transition-old(thought-card-active) {
      animation: none;
    }
  }
</style>
