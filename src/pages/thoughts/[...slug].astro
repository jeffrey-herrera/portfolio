---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import MainContent from '../../components/MainContent.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import { Image } from 'astro:assets';
import { formatReadTime, getReadTimeMinutes } from '../../utils/readTime';
import { PALETTE, computePaletteMap } from '../../utils/palette';

export async function getStaticPaths() {
  const thoughtEntries = await getCollection('thoughts');
  const paletteMap = computePaletteMap(thoughtEntries);

  return thoughtEntries.map(entry => ({
    params: { slug: entry.slug },
    props: { entry, palette: paletteMap.get(entry.slug)! },
  }));
}

const { entry, palette } = Astro.props;
const { Content } = await entry.render();
const readTimeMinutes = getReadTimeMinutes(entry.body);

const articleJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: entry.data.title,
  description: entry.data.description,
  datePublished: entry.data.publishedAt?.toISOString(),
  author: { '@type': 'Person', name: 'Jeff Herrera' },
  url: new URL(`/thoughts/${entry.slug}`, Astro.site).href,
};
---

<Layout
  title={`${entry.data.title} — Jeff Herrera`}
  description={entry.data.description}
  ogImage={`/og/thoughts/${entry.slug}.png`}
  jsonLd={articleJsonLd}
>
  <MainContent>
    <div class="page-inner" style={`--card-bg:${palette.bg};--card-title:${palette.title};--card-excerpt:${palette.excerpt}`}>

      <Breadcrumb crumbs={[{ label: 'Thoughts', href: '/thoughts' }, { label: entry.data.title }]} />

      <!-- Ticket stub header -->
      <div class="thought-ticket">
        {entry.data.cover && (
          <div class="ticket-image">
            <Image
              src={entry.data.cover}
              alt={entry.data.title}
              width={600}
              height={338}
              class="ticket-cover"
              loading="eager"
            />
          </div>
        )}
        <div class="ticket-info">
          <div class="ticket-text">
            <h1 class="ticket-title">{entry.data.title}</h1>
            <p class="ticket-desc">{entry.data.description}</p>
          </div>
          <div class="ticket-meta">
            <div class="meta-stack">
              <span><span class="meta-label">DATE</span>{entry.data.publishedAt.toLocaleDateString('en-US', { month: '2-digit', day: '2-digit', year: '2-digit' })}</span>
              <span><span class="meta-label">READ</span>{formatReadTime(readTimeMinutes)}</span>
            </div>
            <button class="share-btn" id="share-btn" type="button">Share</button>
          </div>
        </div>
      </div>

      <!-- Body -->
      <div class="thought-body prose">
        <Content />
      </div>

    </div>
  </MainContent>
</Layout>

<style>
  .page-inner {
    padding-top: 40px;
  }

  /* ── Ticket stub header ──────────────────────────────────────────────── */
  .thought-ticket {
    display: grid;
    grid-template-columns: 1fr 1fr;
    background: var(--card-bg);
    border-radius: 10px 10px 2px 2px;
    overflow: hidden;
    position: relative;
    margin-bottom: 60px;
  }

  /* Perforated bottom edge */
  .thought-ticket::after {
    content: '';
    position: absolute;
    bottom: -12px;
    left: 0;
    right: 0;
    height: 24px;
    background: radial-gradient(circle, var(--color-cream) 12px, transparent 12px)
      center / 32px 24px repeat-x;
    pointer-events: none;
    z-index: 2;
  }

  .ticket-image {
    overflow: hidden;
  }

  .ticket-cover {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    opacity: 0.88;
    transition: opacity 0.3s ease;
  }

  .ticket-info {
    order: -1;
    padding: clamp(32px, 4vw, 40px);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    text-wrap: balance;
    gap: 12px;
  }

  .ticket-title {
    font-family: var(--font-sans);
    font-size: clamp(28px, 3vw, 48px);
    font-weight: 700;
    line-height: 1.1;
    color: var(--card-title);
    margin-bottom: 10px;
  }

  .ticket-desc {
    font-family: var(--font-sans);
    font-size: clamp(14px, 1.5vw, 24px);
    line-height: 1.45;
    color: color-mix(in srgb, var(--card-title) 70%, var(--card-bg));
    margin: 0 0 20px 0;
    text-wrap: balance;
  }

  .ticket-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    margin-top: 8px;
    padding-top: 12px;
    border-top: 1px dashed color-mix(in srgb, var(--card-title) 30%, var(--card-bg));
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--card-title) 55%, var(--card-bg));
  }

  .meta-stack {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .meta-label {
    opacity: 0.5;
    margin-right: 5px;
  }

  /* ── Body — no container, sits on page bg ────────────────────────────── */
  .thought-body {
    font-family: var(--font-sans);
    font-size: 19px;
    line-height: 1.7;
    color: var(--color-orange-950);
    /* max-width: 760px; */
  }

  .thought-body :global(h2) {
    font-family: var(--font-sans);
    font-size: 28px;
    letter-spacing: -0.56px;
    color: var(--color-orange-950);
    margin: 40px 0 16px;
  }

  .thought-body :global(p) {
    margin: 0 0 24px;
    color: var(--color-orange-950);
  }

  .thought-body :global(a) {
    color: var(--color-orange-500);
    text-decoration: none;
  }

  .thought-body :global(a:hover) {
    text-decoration: underline;
  }

  /* ── Lede / closing mark — works at both top and bottom of body ──────── */
  /* Mark wrapper — Markdown wraps <mark> in a <p>, so target that */
  .thought-body :global(p:has(> mark)) {
    background: none;
    margin-top: 8px;
    margin-bottom: 40px;
  }

  .thought-body :global(mark) {
    background: none;
    font-family: var(--font-sans);
    font-size: 28px;
    line-height: 1.35;
    color: var(--color-orange-950);
    display: block;
  }

  /* Closing mark — <p> containing <mark> that follows body copy */
  .thought-body :global(p + p:has(> mark)),
  .thought-body :global(ul + p:has(> mark)) {
    margin-top: 40px;
    margin-bottom: 8px;
  }

  /* ── Entrance animation ──────────────────────────────────────────────── */
  @keyframes thoughtFadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .thought-ticket {
    animation: thoughtFadeUp 0.8s cubic-bezier(0.25, 0, 0, 1) 0.1s both;
  }

  .thought-body {
    animation: thoughtFadeUp 0.8s cubic-bezier(0.25, 0, 0, 1) 0.3s both;
  }

  @media (prefers-reduced-motion: reduce) {
    .thought-ticket,
    .thought-body { animation: none; }
  }

  /* ── Mobile ──────────────────────────────────────────────────────────── */
  @media (max-width: 1023px) {
    .thought-ticket {
      grid-template-columns: 1fr;
    }

    .ticket-image {
      aspect-ratio: 16 / 9;
    }

    .ticket-cover {
      height: 100%;
    }

    .ticket-info {
      padding: 32px 24px 40px;
    }

    .ticket-title {
      font-size: 26px;
    }
  }

  /* ── Share button ─────────────────────────────────────────────────────── */
  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 8px 18px;
    border-radius: 999px;
    border: 1px solid color-mix(in srgb, var(--card-title) 35%, var(--card-bg));
    background: transparent;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: color-mix(in srgb, var(--card-title) 70%, var(--card-bg));
    cursor: pointer;
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }

  .share-btn:hover {
    border-color: var(--card-title);
    color: var(--card-title);
  }
</style>

<script>
  function initShare() {
    const btn = document.getElementById('share-btn') as HTMLButtonElement | null;
    if (!btn) return;

    const onClick = () => {
      navigator.clipboard.writeText(location.href).then(() => {
        const prev = btn.textContent!.trim();
        btn.textContent = 'Copied \u2713';
        setTimeout(() => { btn.textContent = prev; }, 2000);
        const slug = location.pathname.split('/').filter(Boolean).pop() ?? '';
        import('@vercel/analytics').then(({ track }) => {
          track('thought_shared', { slug });
        }).catch(() => {});
      });
    };

    btn.addEventListener('click', onClick);
    document.addEventListener('astro:before-swap', () => {
      btn.removeEventListener('click', onClick);
    }, { once: true });
  }

  initShare();
  document.addEventListener('astro:after-swap', initShare);
</script>

