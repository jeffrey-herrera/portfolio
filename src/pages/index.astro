---
import Layout from '../layouts/Layout.astro';
import MainContent from '../components/MainContent.astro';
import Button from '../components/Button.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const allWork = await getCollection('work');

const brandWork    = allWork.filter(w => w.data.tags.some(t => t.toLowerCase() === 'brand'));
const physicalWork = allWork.filter(w => w.data.tags.some(t => t.toLowerCase() === 'physical'));
const digitalWork  = allWork.filter(w => w.data.tags.some(t => t.toLowerCase() === 'digital'));

const categories = [
  { name: 'Brand',    items: brandWork    },
  { name: 'Physical', items: physicalWork },
  { name: 'Digital',  items: digitalWork  },
];
---

<Layout>
  <MainContent>
    <div class="hero row">
    <!-- Canvas for velocity-based cursor trail — sits behind hero text -->
    <canvas class="hero-trail-canvas" aria-hidden="true"></canvas>

    <!-- Hero text — each word wrapped in .word-clip for clip-mask entrance  -->
    <div class="hero-text">
      <span class="word-clip" style="--i:0"><span class="word word--sans word--orange">I'M</span></span>
      <span class="word-clip" style="--i:1"><span class="word word--sans word--orange">JEFF,</span></span>
      
      <!-- Portrait pill — opacity+scale entrance (clip not used: shadow needs overflow:visible) -->
      <span class="hero-pill hero-entrance" style="--i:3">
        <span class="hero-pill__shadow">
          <span class="pill-orange-bg"></span>
          <Image src="/portrait.jpg" alt="" aria-hidden="true" class="pill-portrait-img" width={300} height={375} loading="eager" />
        </span>
        <span class="hero-pill__main">
          <span class="pill-orange-bg"></span>
          <Image src="/portrait.jpg" alt="Jeff Herrera" class="pill-portrait-img" width={300} height={375} loading="eager" />
        </span>
      </span>
      
      <span class="word-clip" style="--i:2"><span class="word word--sans word--orange">a</span></span>
      <span class="word-clip" style="--i:4"><span class="word word--sans word--orange">creative</span></span>
      <span class="word-clip" style="--i:5"><span class="word word--sans word--orange">director</span></span>
      <span class="word-clip" style="--i:6"><span class="word word--sans word--orange">based</span></span>
      <span class="word-clip" style="--i:7"><span class="word word--sans word--orange">in</span></span>
      <span class="word-clip" style="--i:8"><span class="word word--sans word--orange">NYC,</span></span>

      <!-- NYC pill
      <span class="hero-pill hero-entrance" style="--i:9">
        <span class="hero-pill__shadow">
          <img src="/nyc.jpg" alt="" aria-hidden="true" class="pill-nyc-img" />
        </span>
        <span class="hero-pill__main">
          <img src="/nyc.jpg" alt="NYC" class="pill-nyc-img" />
        </span>
      </span> -->
      <br>

      <!-- Serif words -->
      <span class="word-clip" style="--i:10"><span class="word word--serif word--dark">building</span></span>
      <span class="word-clip" style="--i:11"><span class="word word--serif word--dark">lasting</span></span>
      <span class="word-clip" style="--i:12"><span class="word word--serif word--dark">brands</span></span>
      <span class="word-clip" style="--i:13"><span class="word word--serif word--dark">across</span></span>
      <span class="word-clip" style="--i:14"><span class="word word--serif word--dark">physical</span></span>
      <span class="word-clip" style="--i:15"><span class="word word--serif word--dark">&amp;</span></span>
      <span class="word-clip" style="--i:16"><span class="word word--serif word--dark">digital.</span></span>
    </div>

      
    </div>

    <!-- About blurb -->
    <div class="about-zone row">
      <div class="about-content">
        <p class="about-text">
          Currently Associate Creative Director of Brand &amp; Experiential / Competitive Cold Brew Drinker at Braze
        </p>
        <Button href="/about" variant="secondary" class="about-btn">
          About <span>→</span>
        </Button>
      </div>
    </div>

    <!-- Work sections -->
    <div class="work-sections">

      <!-- <h2 class="work-heading">
        <span class="reveal-outer"><span class="reveal-inner">Selected Work &darr;</span></span>
      </h2> -->

      {categories.map((category) => (
        <div id={category.name.toLowerCase()} class="category-card">

          <div class="category-header">
            <span class="category-name"><span class="reveal-inner">{category.name}</span></span>
            <span class="category-count" data-count={category.items.length}>{category.items.length}</span>
          </div>

          {category.items.length === 0 ? (
            <p class="empty-state">No {category.name} projects yet</p>
          ) : (
            <div class="projects-list">
              {category.items[0] && (
                <a href={`/work/${category.items[0].slug}`} class="project-link" data-cursor-label="View Project">
                  <div class="project-card project-card--large">
                    <div class="project-image project-image--wide" transition:name={`work-cover-${category.items[0].slug}`}>
                      {category.items[0].data.cover
                        ? <Image src={category.items[0].data.cover} alt={category.items[0].data.title} class="project-img" width={800} height={500} loading="eager" />
                        : <div class="project-placeholder"></div>
                      }
                    </div>
                    <div class="project-info">
                      <span class="project-title" transition:name={`work-title-${category.items[0].slug}`}>{category.items[0].data.title}</span>
                      <span class="project-cat">{category.name}</span>
                    </div>
                  </div>
                </a>
              )}

              {category.items.length > 1 && (
                (() => {
                  const rest = category.items.slice(1);
                  const pairs = [];
                  for (let i = 0; i < rest.length; i += 2) {
                    pairs.push(rest.slice(i, i + 2));
                  }
                  return pairs.map((pair) => (
                    <div class="project-row">
                      {pair.map((item) => (
                        <a href={`/work/${item.slug}`} class="project-link project-link--half" data-cursor-label="View Project">
                          <div class="project-card">
                            <div class="project-image project-image--square" transition:name={`work-cover-${item.slug}`}>
                              {item.data.cover
                                ? <Image src={item.data.cover} alt={item.data.title} class="project-img" width={400} height={400} />
                                : <div class="project-placeholder"></div>
                              }
                            </div>
                            <div class="project-info">
                              <span class="project-title" transition:name={`work-title-${item.slug}`}>{item.data.title}</span>
                              <span class="project-cat">{item.data.tags[0]}</span>
                            </div>
                          </div>
                        </a>
                      ))}
                      {pair.length === 1 && <div class="project-link--half"></div>}
                    </div>
                  ));
                })()
              )}
            </div>
          )}
        </div>
      ))}
    </div>

  </MainContent>
</Layout>

<script>
  import { initMagnetic } from '../utils/magnetic.ts';

  // ── Work nav + back-to-top scroll reveal ─────────────────────────────────
  function initWorkNavScroll() {
    const workSections = document.querySelector('.work-sections') as HTMLElement | null;
    const workNav      = document.querySelector('.sidebar-work-nav')  as HTMLElement | null;
    const backTop      = document.getElementById('sidebar-back-top') as HTMLElement | null;

    if (!workSections || !workNav) return;

    const workAbsTop   = workSections.getBoundingClientRect().top + window.scrollY;
    const triggerPoint = workAbsTop + 200;

    let backTopShown = false;

    const onScroll = () => {
      workNav.classList.toggle('visible', window.scrollY >= triggerPoint);

      if (backTop) {
        const scrollable = document.documentElement.scrollHeight - window.innerHeight;
        const pct = scrollable > 0 ? window.scrollY / scrollable : 0;
        // Latch: show once threshold is crossed, only hide when scrolling back up
        if (!backTopShown && pct >= 0.4) {
          backTopShown = true;
        } else if (backTopShown && pct < 0.4) {
          backTopShown = false;
        }
        backTop.classList.toggle('visible', backTopShown);
      }
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();

    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', onScroll);
    }, { once: true });
  }

  // ── Scroll-triggered reveals (.reveal-inner → .is-revealed) ─────────────
  // IMPORTANT: We observe the PARENT of .reveal-inner, not .reveal-inner itself.
  // IO uses getBoundingClientRect() which follows CSS transforms — so .reveal-inner
  // at translateY(110%) appears off-screen to the observer even when the heading
  // is visually in the viewport. The parent (.reveal-outer / .category-name) sits
  // in normal layout flow, so its bounding box is always correct.
  function initScrollReveals() {
    const inners = document.querySelectorAll<HTMLElement>('.reveal-inner');
    if (!inners.length) return;

    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const inner = (entry.target as HTMLElement).querySelector<HTMLElement>('.reveal-inner');
        if (inner) inner.classList.add('is-revealed');
        io.unobserve(entry.target);
      });
    }, { threshold: 0.15, rootMargin: '0px 0px -5% 0px' });

    // Observe each .reveal-inner's parent (which is in normal layout flow)
    inners.forEach(inner => {
      if (inner.parentElement) io.observe(inner.parentElement);
    });
    document.addEventListener('astro:before-swap', () => io.disconnect(), { once: true });
  }

  // ── Image parallax ───────────────────────────────────────────────────────
  // CSS owns `scale` (including hover); JS owns `translate` only — no conflict.
  function initParallax() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const imgs = Array.from(document.querySelectorAll<HTMLElement>('.project-img'));
    if (!imgs.length) return;

    let ticking = false;
    const onScroll = () => {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(() => {
        const vh = window.innerHeight;
        imgs.forEach(img => {
          const container = img.closest('.project-image') as HTMLElement | null;
          if (!container) return;
          const rect     = container.getBoundingClientRect();
          const progress = (vh - rect.top) / (vh + rect.height);
          const clamped  = Math.max(0, Math.min(1, progress));
          const shift    = (clamped - 0.5) * -30; // ±15px
          img.style.translate = `0 ${shift}px`;
        });
        ticking = false;
      });
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll();
    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', onScroll);
    }, { once: true });
  }

  // ── Active section tracking → sidebar .is-active ─────────────────────────
  function initActiveSections() {
    const sidebarLinks = document.querySelectorAll<HTMLElement>('.sidebar-work-nav .sidebar-link');
    if (!sidebarLinks.length) return;

    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const id = (entry.target as HTMLElement).id;
        sidebarLinks.forEach(link => {
          link.classList.toggle('is-active', link.getAttribute('href') === `/#${id}`);
        });
      });
    }, { rootMargin: '-25% 0px -65% 0px' });

    ['brand', 'physical', 'digital'].forEach(id => {
      const el = document.getElementById(id);
      if (el) io.observe(el);
    });

    document.addEventListener('astro:before-swap', () => io.disconnect(), { once: true });
  }

  // ── Magnetic about button ─────────────────────────────────────────────────
  function initAboutMagnetic() {
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
    const btn = document.querySelector<HTMLElement>('.about-btn');
    if (!btn) return;

    const cleanup = initMagnetic(btn, { strength: 0.38, radiusMultiplier: 1.6 });
    document.addEventListener('astro:before-swap', cleanup, { once: true });
  }

  // ── Category count roll-up ────────────────────────────────────────────────
  function initCounts() {
    const counts = document.querySelectorAll<HTMLElement>('.category-count[data-count]');
    if (!counts.length) return;

    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el     = entry.target as HTMLElement;
        const target = parseInt(el.dataset.count ?? '0', 10);
        if (target === 0) return;
        io.unobserve(el);

        const duration = 600;
        const start    = performance.now();
        const tick     = (now: number) => {
          const t     = Math.min(1, (now - start) / duration);
          const eased = 1 - (1 - t) * (1 - t); // ease-out quad
          el.textContent = String(Math.round(eased * target));
          if (t < 1) requestAnimationFrame(tick);
          else el.textContent = String(target); // snap to final value
        };
        requestAnimationFrame(tick);
      });
    }, { threshold: 0.5 });

    counts.forEach(el => io.observe(el));
    document.addEventListener('astro:before-swap', () => io.disconnect(), { once: true });
  }

  // ── Project card entrance — Option B: staggered fade + slide-up ──────────
  // Large card enters first; within each pair, the right card is delayed 90ms.
  function initProjectCards() {
    const cards = document.querySelectorAll<HTMLElement>('a.project-link');
    if (!cards.length) return;

    const io = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (!entry.isIntersecting) return;
        const el = entry.target as HTMLElement;

        // Stagger right card in a pair
        const row = el.closest('.project-row');
        if (row) {
          const siblings = Array.from(row.querySelectorAll<HTMLElement>('a.project-link'));
          const idx = siblings.indexOf(el);
          if (idx > 0) el.style.setProperty('--enter-delay', `${idx * 90}ms`);
        }

        el.classList.add('is-visible');
        io.unobserve(el);
      });
    }, { threshold: 0.08 });

    cards.forEach(card => io.observe(card));
    document.addEventListener('astro:before-swap', () => io.disconnect(), { once: true });
  }

  // ── Hero cursor trail (canvas, velocity-based dots) ─────────────────────
  // Only on pointer devices; respects prefers-reduced-motion.
  // Orange dots spawn when the cursor moves fast; fade out over ~20 frames.
  function initHeroCursorTrail() {
    if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;
    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    const canvas   = document.querySelector<HTMLCanvasElement>('.hero-trail-canvas');
    const heroText = document.querySelector<HTMLElement>('.hero-text');
    if (!canvas || !heroText) return;

    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    // Match canvas resolution to its CSS size
    const syncSize = () => {
      const r = canvas.getBoundingClientRect();
      canvas.width  = Math.round(r.width  * devicePixelRatio);
      canvas.height = Math.round(r.height * devicePixelRatio);
    };
    syncSize();

    type Dot = { x: number; y: number; r: number; age: number; maxAge: number };
    let dots: Dot[] = [];
    let rafId: number;

    const renderFrame = (draining = false) => {
      const dpr = devicePixelRatio;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.save();
      ctx.scale(dpr, dpr);

      dots = dots.filter(d => d.age <= d.maxAge);

      for (const d of dots) {
        const t       = d.age / d.maxAge;
        const opacity = (1 - t) * (1 - t) * 0.24;   // quadratic fade
        const radius  = d.r * (1 - t * 0.45);        // slight shrink as it ages
        ctx.beginPath();
        ctx.arc(d.x, d.y, radius, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255, 105, 0, ${opacity})`; // orange-500
        ctx.fill();
        d.age++;
      }

      ctx.restore();

      if (draining && !dots.length) {
        cancelAnimationFrame(rafId);
      } else {
        rafId = requestAnimationFrame(() => renderFrame(draining));
      }
    };

    const onMove = (e: MouseEvent) => {
      const rect  = canvas.getBoundingClientRect();
      const speed = Math.sqrt(e.movementX ** 2 + e.movementY ** 2);
      if (speed < 2.5) return; // ignore slow drift

      dots.push({
        x:      e.clientX - rect.left,
        y:      e.clientY - rect.top,
        r:      Math.min(2.5 + speed * 0.35, 9),
        age:    0,
        maxAge: 16 + Math.floor(Math.random() * 10),
      });
    };

    const onEnter = () => {
      heroText.addEventListener('mousemove', onMove);
      cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(() => renderFrame(false));
    };

    const onLeave = () => {
      heroText.removeEventListener('mousemove', onMove);
      // Let remaining dots fade out, then stop
      cancelAnimationFrame(rafId);
      rafId = requestAnimationFrame(() => renderFrame(true));
    };

    heroText.addEventListener('mouseenter', onEnter);
    heroText.addEventListener('mouseleave', onLeave);

    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(rafId);
      heroText.removeEventListener('mouseenter', onEnter);
      heroText.removeEventListener('mouseleave', onLeave);
      heroText.removeEventListener('mousemove', onMove);
    }, { once: true });
  }

  // ── Init all ─────────────────────────────────────────────────────────────
  function initAll() {
    initWorkNavScroll();
    initScrollReveals();
    initProjectCards();
    initParallax();
    initActiveSections();
    initAboutMagnetic();
    initCounts();
    initHeroCursorTrail();
  }

  initAll();
  document.addEventListener('astro:after-swap', initAll);
</script>

<style>

  /* ===== HERO ===== */
  .hero {
    position: relative; /* needed so canvas can fill this container */
  }

  /* Cursor trail canvas — absolutely fills the hero, pointer-events off */
  .hero-trail-canvas {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 0;
  }

  /* ===== HERO TEXT ===== */
  .hero-text {
    position: relative; /* sit above the canvas */
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    grid-column: 1 / 8;
    align-content: flex-start;
    padding-top: 112px;
    gap: 0 16px;
    min-height: 436px;
  }

  .word {
    white-space: nowrap;
    line-height: 1.15;
    /* Fluid from 24px on small phones up to 80px at desktop.
       letter-spacing in em so it scales proportionally. */
    font-size: clamp(2.4rem, 5.5vw, 5rem);
    letter-spacing: -0.014em;
  }

  .word--sans {
    font-family: var(--font-uncut);
    font-weight: 700;
    text-transform: uppercase;
    font-feature-settings: 'ordn' 1, 'dlig' 1;
  }

  .word--serif {
    font-family: var(--font-fragment);
    font-weight: 400;
    font-feature-settings: 'ordn' 1, 'ss04' 1, 'ss03' 1, 'dlig' 1;
  }

  .word--orange { color: var(--color-orange-500); }
  .word--dark   { color: var(--color-orange-950); }

  /* ── Word clip: hides word until it slides up ─────────────────────────── */
  .word-clip {
    overflow: hidden;
    display: inline-flex;
    vertical-align: middle;
    line-height: 1.15; /* match .word so clip height is correct */
    /* Extra room below baseline for descenders (g, p, y, j…).
       Negative margin-bottom cancels the layout effect so flex row height
       stays identical — only the clip boundary moves. */
    padding-bottom: 0.32em;
    margin-bottom: -0.32em;
  }

  /* Slide up from below the clip boundary on page load */
  .word-clip .word {
    animation: heroWordUp 0.85s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(var(--i, 0) * 50ms);
  }

  @keyframes heroWordUp {
    from { transform: translateY(110%); }
    to   { transform: translateY(0); }
  }

  /* ── Pill entrance: fade + rise (no clip — shadow uses filter:blur) ────── */
  .hero-entrance {
    animation: heroPillIn 0.75s cubic-bezier(0.16, 1, 0.3, 1) both;
    animation-delay: calc(var(--i, 0) * 50ms);
  }

  @keyframes heroPillIn {
    from { opacity: 0; transform: translateY(16px) scale(0.92); }
    to   { opacity: 1; transform: translateY(0)    scale(1); }
  }

  .hero-pill {
    display: inline-flex;
    width: 130px;
    height: 64px;
    flex-shrink: 0;
    position: relative;
    vertical-align: middle;
  }

  /* Blurred shadow — same pill content, offset down + blurred */
  .hero-pill__shadow {
    position: absolute;
    left: 0;
    top: 5px;
    width: 100%;
    height: 100%;
    border-radius: 999px;
    overflow: hidden;
    filter: blur(12px);
    opacity: 0.6;
  }

  /* Main visible pill */
  .hero-pill__main {
    position: relative;
    width: 100%;
    height: 100%;
    border-radius: 999px;
    overflow: hidden;
    flex-shrink: 0;
  }

  /* Portrait pill — orange background layer */
  .pill-orange-bg {
    position: absolute;
    inset: 0;
    background: var(--color-orange-500);
  }

  /* Portrait photo — positioned to show face in upper-center of pill */
  .pill-portrait-img {
    position: absolute;
    width: 221%;
    height: auto;
    left: -60%;
    top: -49%;
    max-width: none;
    pointer-events: none;
  }

  /* NYC photo — fills pill */
  .pill-nyc-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    max-width: none;
    pointer-events: none;
  }

  /* ===== ABOUT ZONE ===== */
  .about-zone {
    margin-top: 60px;
    margin-bottom: 160px;
  }

  .about-content {
    grid-column: 1 / 6;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .about-text {
    font-family: var(--font-uncut);
    font-size: clamp(0.875rem, 3.5vw, 1.375rem);
    letter-spacing: -0.36px;
    line-height: 1.15;
    color: var(--color-taupe-400);
    margin: 0;
    text-wrap: balance;
  }

  /* .about-btn styles live in Button.astro (variant="secondary") */
  .about-btn {
    will-change: transform;
    transition: border-color 0.15s, color 0.15s, transform 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    width: fit-content;
  }

  /* ===== WORK SECTIONS ===== */
  .work-sections {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding-bottom: 80px;
  }

  /* Clip container for scroll-triggered text reveals */
  .reveal-outer {
    display: block;
    overflow: hidden;
  }

  /* Section entry header — large editorial serif */
  .work-heading {
    font-family: var(--font-uncut);
    font-size: clamp(1.5rem, 5vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.5px;
    line-height: 1;
    color: var(--color-taupe-300);
    font-feature-settings: 'ss03' 1, 'ss04' 1, 'dlig' 1;
    margin: 0 0 48px 0;
  }

  /* Category sections */
  .category-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    margin-top: 72px;
    scroll-margin-top: 80px;
  }

  .category-card:first-of-type {
    margin-top: 0;
  }

  /* Category header */
  .category-header {
    display: flex;
    gap: 4px;
    align-items: flex-start;
    padding: 24px 0;
    overflow: hidden;
  }

  .category-name {
    font-family: var(--font-fragment);
    font-size: 24px;
    letter-spacing: -0.24px;
    line-height: 1;
    color: var(--color-orange-950);
    overflow: hidden; /* clip container for inner reveal-inner */
    /* Extend clip boundary above & below to prevent ascender/descender clipping.
       Negative margins cancel the layout effect — only the clip boundary moves. */
    padding-top: 0.18em;
    margin-top: -0.18em;
    padding-bottom: 0.25em;
    margin-bottom: -0.25em;
  }

