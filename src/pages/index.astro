---
import Layout from '../layouts/Layout.astro';
import MainContent from '../components/MainContent.astro';
import { getCollection } from 'astro:content';

const allWork = await getCollection('work');

const brandWork = allWork.filter(w => w.data.tags.some(t => t.toLowerCase() === 'brand'));
const physicalWork = allWork.filter(w => w.data.tags.some(t => t.toLowerCase() === 'physical'));
const digitalWork = allWork.filter(w => w.data.tags.some(t => t.toLowerCase() === 'digital'));

const categories = [
  { name: 'Brand', items: brandWork },
  { name: 'Physical', items: physicalWork },
  { name: 'Digital', items: digitalWork },
];
---

<Layout>
  <MainContent>

    <!-- Hero text -->
    <div class="hero-text">
      <span class="word word--sans word--orange">I'M</span>
      <span class="word word--sans word--orange">JEFF,</span>
      <span class="word word--sans word--orange">a</span>

      <!-- Orange glow pill -->
      <span class="hero-pill hero-pill--orange">
        <span class="hero-pill__glow"></span>
      </span>

      <span class="word word--sans word--orange">creative</span>
      <span class="word word--sans word--orange">director</span>
      <span class="word word--sans word--orange">based</span>
      <span class="word word--sans word--orange">in</span>
      <span class="word word--sans word--orange">NYC,</span>

      <!-- Photo pill -->
      <span class="hero-pill hero-pill--photo">
        <img
          src="/headshot.jpg"
          alt=""
          class="hero-pill__img"
          onerror="this.style.display='none'"
        />
      </span>

      <!-- Serif words -->
      <span class="word word--serif word--dark">building</span>
      <span class="word word--serif word--dark">lasting</span>
      <span class="word word--serif word--dark">brands</span>
      <span class="word word--serif word--dark">across</span>
      <span class="word word--serif word--dark">physical</span>
      <span class="word word--serif word--dark">&amp;</span>
      <span class="word word--serif word--dark">digital.</span>
    </div>

    <!-- About blurb -->
    <div class="about-zone row">
      <div class="about-content">
        <p class="about-text">
          Currently Associate Creative Director of Brand &amp; Experiential / Competitive Cold Brew Drinker at Braze
        </p>
        <a href="/about" class="about-btn">
          About <span>→</span>
        </a>
      </div>
    </div>

    <!-- Work sections -->
    <div class="work-sections">

      <h2 class="work-heading">Selected Work ↓</h2>

      {categories.map((category) => (
        <div id={category.name.toLowerCase()} class="category-card">

          <div class="category-header">
            <span class="category-name">{category.name}</span>
            <span class="category-count">{category.items.length}</span>
          </div>

          {category.items.length === 0 ? (
            <p class="empty-state">No {category.name} projects yet</p>
          ) : (
            <div class="projects-list">
              {category.items[0] && (
                <a href={`/work/${category.items[0].slug}`} class="project-link">
                  <div class="project-card project-card--large">
                    <div class="project-image project-image--wide">
                      {category.items[0].data.cover
                        ? <img src={category.items[0].data.cover} alt={category.items[0].data.title} class="project-img" />
                        : <div class="project-placeholder"></div>
                      }
                    </div>
                    <div class="project-info">
                      <span class="project-title">{category.items[0].data.title}</span>
                      <span class="project-cat">{category.name}</span>
                    </div>
                  </div>
                </a>
              )}

              {category.items.length > 1 && (
                (() => {
                  const rest = category.items.slice(1);
                  const pairs = [];
                  for (let i = 0; i < rest.length; i += 2) {
                    pairs.push(rest.slice(i, i + 2));
                  }
                  return pairs.map((pair) => (
                    <div class="project-row">
                      {pair.map((item) => (
                        <a href={`/work/${item.slug}`} class="project-link project-link--half">
                          <div class="project-card">
                            <div class="project-image project-image--square">
                              {item.data.cover
                                ? <img src={item.data.cover} alt={item.data.title} class="project-img" />
                                : <div class="project-placeholder"></div>
                              }
                            </div>
                            <div class="project-info">
                              <span class="project-title">{item.data.title}</span>
                              <span class="project-cat">{item.data.tags[0]}</span>
                            </div>
                          </div>
                        </a>
                      ))}
                      {pair.length === 1 && <div class="project-link--half"></div>}
                    </div>
                  ));
                })()
              )}
            </div>
          )}
        </div>
      ))}
    </div>

  </MainContent>
</Layout>

<script>
  function initWorkNavScroll() {
    const workSections = document.querySelector('.work-sections') as HTMLElement | null;
    const workNav = document.querySelector('.sidebar-work-nav') as HTMLElement | null;

    if (!workSections || !workNav) return;

    // Cache the work section's absolute position from the document top
    const workAbsTop = workSections.getBoundingClientRect().top + window.scrollY;
    const triggerPoint = workAbsTop + 200;

    const onScroll = () => {
      if (window.scrollY >= triggerPoint) {
        workNav.classList.add('visible');
      } else {
        workNav.classList.remove('visible');
      }
    };

    window.addEventListener('scroll', onScroll, { passive: true });
    onScroll(); // run once immediately to set correct initial state

    // Clean up listener before View Transition swaps the page
    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', onScroll);
    }, { once: true });
  }

  // Run on first load and after every View Transition
  initWorkNavScroll();
  document.addEventListener('astro:after-swap', initWorkNavScroll);
</script>

<style>

  /* ===== HERO TEXT ===== */
  .hero-text {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    align-content: flex-start;
    padding-top: 112px;
    gap: 0 16px;
    min-height: 436px;
  }

  .word {
    white-space: nowrap;
    line-height: 1.15;
    letter-spacing: -1.12px;
    font-size: 72px;
  }

  .word--sans {
    font-family: var(--font-uncut);
    font-weight: 700;
    text-transform: uppercase;
    font-feature-settings: 'ordn' 1, 'dlig' 1;
  }

  .word--serif {
    font-family: var(--font-fragment);
    font-weight: 400;
    font-feature-settings: 'ordn' 1, 'ss04' 1, 'ss03' 1, 'dlig' 1;
  }

  .word--orange { color: var(--color-orange-500); }
  .word--dark   { color: var(--color-orange-950); }

  .hero-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 130px;
    height: 64px;
    border-radius: 999px;
    flex-shrink: 0;
    overflow: hidden;
    position: relative;
  }

  .hero-pill--orange {
    background: var(--color-orange-500);
    box-shadow: 0 5px 12px oklch(from var(--color-orange-500) l c h / 0.55);
  }

  .hero-pill__glow {
    position: absolute;
    inset: 0;
    border-radius: 999px;
    background: radial-gradient(ellipse at 35% 35%, oklch(from var(--color-orange-500) calc(l + 0.25) calc(c - 0.1) h / 0.45) 0%, transparent 65%);
  }

  .hero-pill--photo { background: var(--color-taupe-300); }

  .hero-pill__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ===== ABOUT ZONE ===== */
  .about-zone {
    margin-top: 60px;
    margin-bottom: 160px;
  }

  .about-content {
    grid-column: 4 / 8;
    display: flex;
    flex-direction: column;
    gap: 15px;
  }

  .about-text {
    font-family: var(--font-uncut);
    font-size: 20px;
    font-weight: 500;
    letter-spacing: -0.36px;
    line-height: 1.15;
    color: var(--color-taupe-400);
    margin: 0;
    text-wrap: balance;
    margin-bottom: 20px;
  }

  .about-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--color-taupe-400);
    border-radius: 999px;
    padding: 12px 20px;
    font-family: var(--font-uncut);
    font-size: 16px;
    font-weight: 500;
    letter-spacing: -0.28px;
    color: var(--color-taupe-400);
    text-decoration: none;
    transition: border-color 0.15s, color 0.15s;
    width: fit-content;
  }

  .about-btn:hover {
    border-color: var(--color-orange-500);
    color: var(--color-orange-500);
  }

  /* ===== WORK SECTIONS ===== */
  .work-sections {
    display: flex;
    flex-direction: column;
    gap: 40px;
    position: relative;
    isolation: isolate;
  }

  .work-heading {
    position: absolute;
    top: -40px;
    left: 0;
    width: 100%;
    font-family: var(--font-uncut);
    font-weight: 700;
    font-size: 48px;
    line-height: 1;
    letter-spacing: -1%;
    text-transform: uppercase;
    color: var(--color-taupe-300);
    margin: 0;
    pointer-events: none;
    z-index: -1;
  }

  /* Category cards */
  .category-card {
    background: white;
    border-radius: 6px;
    padding: 10px 20px 40px;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .category-header {
    display: flex;
    gap: 2px;
    align-items: flex-start;
    padding: 24px 0;
    overflow: hidden;
  }

  .category-name {
    font-family: var(--font-fragment);
    font-size: 24px;
    letter-spacing: -1%;
    line-height: 1;
    color: var(--color-orange-950);
  }

  .category-count {
    font-family: var(--font-uncut);
    font-size: 12px;
    letter-spacing: -0.2px;
    line-height: 1;
    color: var(--color-orange-500);
  }

  .empty-state {
    font-family: var(--font-uncut);
    font-size: 14px;
    color: var(--color-taupe-400);
    text-align: center;
    padding: 48px 0;
    margin: 0;
  }

  /* Projects */
  .projects-list {
    display: flex;
    flex-direction: column;
    gap: 48px;
  }

  .project-link {
    display: block;
    text-decoration: none;
  }

  .project-link--half {
    flex: 1;
    min-width: 0;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .project-row {
    display: flex;
    gap: 48px;
    align-items: flex-start;
  }

  .project-row .project-link {
    flex: 1;
    min-width: 0;
  }

  .project-image {
    border-radius: 2px;
    overflow: hidden;
    width: 100%;
    position: relative;
    background: var(--color-taupe-300);
  }

  .project-image--wide { aspect-ratio: 1920 / 1080; }
  .project-image--square { aspect-ratio: 1 / 1; }

  .project-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  .project-link:hover .project-img { transform: scale(1.01); }

  .project-placeholder {
    width: 100%;
    height: 100%;
    background: var(--color-taupe-300);
    position: absolute;
    inset: 0;
  }

  .project-info {
    display: flex;
    align-items: center;
    gap: 8px;
    line-height: 1.15;
    font-family: var(--font-uncut);
  }

  .project-title {
    font-size: 16px;
    color: var(--color-orange-950);
  }

  .project-cat {
    font-size: 12px;
    color: var(--color-taupe-400);
  }
</style>
