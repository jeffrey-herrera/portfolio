---
import Layout from '../layouts/Layout.astro';
import MainContent from '../components/MainContent.astro';
import PageTitle from '../components/PageTitle.astro';
import Tag from '../components/Tag.astro';
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const allProjects = await getCollection('projects');
const sortedProjects = allProjects.sort(
  (a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf()
);
---

<Layout title="Playground — Jeff Herrera">
  <MainContent>

    <PageTitle title="Playground" />

    {sortedProjects.length === 0 ? (
      <p class="empty-state">No projects yet. Add experiments in <code>src/content/projects/</code></p>
    ) : (
      <div class="projects-grid">
        {sortedProjects.map((project) => (
          <article class="project-card">
            {project.data.cover && (
              <div class="project-cover">
                <Image src={project.data.cover} alt={project.data.title} class="project-img" width={600} height={338} />
              </div>
            )}
            <div class="project-info">
              <h2 class="project-title">{project.data.title}</h2>
              <p class="project-desc">{project.data.description}</p>
              {project.data.tags.length > 0 && (
                <div class="project-tags">
                  {project.data.tags.map((tag) => (
                    <Tag label={tag} />
                  ))}
                </div>
              )}
              <div class="project-links">
                {project.data.url && (
                  <a href={project.data.url} target="_blank" rel="noopener noreferrer" class="project-link">
                    View Project →
                  </a>
                )}
                {project.data.github && (
                  <a href={project.data.github} target="_blank" rel="noopener noreferrer" class="project-link">
                    GitHub →
                  </a>
                )}
              </div>
            </div>
          </article>
        ))}
      </div>
    )}

  </MainContent>
</Layout>

<style>
  .projects-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
  }

  @media (max-width: 1023px) {
    .projects-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
  }

  .project-card {
    background: var(--color-white);
    border-radius: 6px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
  }

  .project-cover {
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-taupe-300);
  }

  .project-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }

  @media (hover: hover) {
    .project-card:hover .project-img {
      transform: scale(1.02);
    }
  }

  .project-info {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }

  .project-title {
    font-family: var(--font-fragment);
    font-size: 20px;
    letter-spacing: -0.4px;
    line-height: 1.2;
    color: var(--color-orange-950);
    margin: 0;
  }

  .project-desc {
    font-family: var(--font-uncut);
    font-size: 14px;
    line-height: 1.5;
    color: var(--color-taupe-400);
    margin: 0;
  }

  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .project-links {
    display: flex;
    gap: 16px;
    margin-top: 4px;
  }

  .project-link {
    font-family: var(--font-uncut);
    font-size: 13px;
    color: var(--color-orange-500);
    text-decoration: none;
    transition: opacity 0.15s;
  }

  .project-link:hover { opacity: 0.7; }
</style>
