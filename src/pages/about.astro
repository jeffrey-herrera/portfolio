---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About - Jeff Herrera">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl md:text-5xl font-bold mb-8">
      About
    </h1>

    <div class="prose prose-zinc dark:prose-invert max-w-none">
      <p class="text-xl text-zinc-600 dark:text-zinc-400 mb-8">
        Product designer and developer with a passion for creating thoughtful digital experiences.
      </p>

      <h2>Background</h2>
      <p>
        Write about your background, experience, and what drives you as a designer and developer.
      </p>

      <h2>Skills</h2>
      <ul>
        <li>Product Design</li>
        <li>User Experience (UX)</li>
        <li>Front-end Development</li>
        <li>Prototyping</li>
      </ul>

      <h2>Get in Touch</h2>
      <p>
        Feel free to reach out if you'd like to collaborate or just chat about design and development.
      </p>
    </div>
  </div>
</BaseLayout>
