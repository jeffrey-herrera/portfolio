---
import Layout from '../layouts/Layout.astro';
import MainContent from '../components/MainContent.astro';
import PageTitle from '../components/PageTitle.astro';
import { Image } from 'astro:assets';

// All 13 portrait photos — each gets a unique object-position for visual variety
const portraits = [
  { src: '/images/about/About1.png',  pos: 'center top'  },
  { src: '/images/about/About2.png',  pos: 'center 15%'  },
  { src: '/images/about/About3.png',  pos: '40% top'     },
  { src: '/images/about/About4.png',  pos: 'center 20%'  },
  { src: '/images/about/About5.png',  pos: '30% top'     },
  { src: '/images/about/About6.png',  pos: '55% top'     },
  { src: '/images/about/About7.png',  pos: 'center top'  },
  { src: '/images/about/About8.png',  pos: '45% 10%'     },
  { src: '/images/about/About9.png',  pos: 'center 15%'  },
  { src: '/images/about/About10.png', pos: '35% top'     },
  { src: '/images/about/About11.png', pos: 'center 20%'  },
  { src: '/images/about/About12.png', pos: '50% top'     },
  { src: '/images/about/About13.png', pos: 'center 10%'  },
];
---

<Layout title="About — Jeff Herrera">
  <MainContent>

    <PageTitle title="About" />

    <div class="page-inner row">
      <div class="page-body">
        <p>
          I'm Jeff, a creative director based in NYC, and I share my creative space with my <s>overlord</s> cat Taco, who has strong opinions and zero interest in mine. With a decade of experience across in-house and freelance roles, I specialize in brand consistency at scale, creative direction for product storytelling, and experiential design. A lot of that work has lived in tech and SaaS, where making complex products feel understandable is half the job...and the other half is keeping up with how fast everything changes.
        </p>
        <p>
          My focus is on building the conditions that make good creative repeatable: strong brand systems, clear process, and a way of working that gives teams room to do their best work. I've found that good structure creates more space for craft, not less. AI fits into that thinking the same way, helping everyone get to clarity faster and see ideas well enough to act.
        </p>
        <p>
          Some concepts I've been thinking about lately are:
          <ul>
            <li>How brands can evolve and scale while staying true to the intent that made them meaningful in the first place</li>
            <li>How process and structure can remove friction, improve collaboration, and give creative work more space to be thoughtful and intentional</li>
            <li>How AI can serve as a bridge between creative vision and real-world context, helping both creatives and non-creatives see ideas clearly, evaluate them confidently, and move them forward</li>
          </ul>
        </p>
      </div>
      <div class="page-sides">
        <div class="page-side">
          <p class="page-side-title">Capabilities</p>
          <ul>
            <li>Identity</li>
            <li>Design Systems</li>
            <li>Brand Refreshes</li>
            <li>Brand Strategy</li>
            <li>Experiential</li>
            <li>Guidelines</li>
            <li>Packaging</li>
            <li>Campaigns</li>
            <li>Wayfinding</li>
            <li>Design Process</li>
            <li>Self-Service Programs</li>
          </ul>
        </div>
        <div class="page-side">
          <p class="page-side-title">Awards</p>
          <ul>
            <li>Identity</li>
            <li>Design Systems</li>
          </ul>
        </div>
      </div>
    </div>

    <!-- Draggable portrait strip -->
    <div class="portrait-strip" data-cursor-type="drag">
      <div class="portrait-track">
        {portraits.map((p) => (
          <div class="portrait-pill">
            <Image
              src={p.src}
              alt=""
              aria-hidden="true"
              class="portrait-img"
              style={`object-position: ${p.pos}`}
              draggable="false"
              width={420}
              height={560}
              loading="eager"
            />
          </div>
        ))}
      </div>
    </div>

  </MainContent>
</Layout>

<script>
  // ── Portrait strip scatter → snap entrance ───────────────────────────────
  // Each pill starts scattered off-screen (random position + rotation), then
  // springs into its natural strip position with a staggered delay.
  // Respects prefers-reduced-motion — if reduced, pills appear immediately.
  function initPortraitScatter() {
    const pills = Array.from(document.querySelectorAll<HTMLElement>('.portrait-pill'));
    const strip = document.querySelector<HTMLElement>('.portrait-strip');
    if (!pills.length || !strip) return;

    if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

    // The strip has clip-path: inset(0 0 0 -9999px) which clips its top and bottom
    // edges exactly at the strip boundary. Scattered pills flying in from below
    // would be invisible until they crossed that boundary.
    // Temporarily open the clip (400px above + below) so the full scatter is visible,
    // then restore the original value once all pills have landed.
    strip.style.clipPath = 'inset(-400px 0 -400px -9999px)';

    // All pills share the same starting offset — bottom-right — so they read
    // as arriving in formation rather than scattering from random positions.
    const OFFSET_X =    0; // no horizontal shift — straight up
    const OFFSET_Y =   32; // px below — subtle lift distance
    const OFFSET_R =    0; // no tilt

    pills.forEach(pill => {
      pill.style.opacity   = '0';
      pill.style.transform = `translate(${OFFSET_X}px, ${OFFSET_Y}px) rotate(${OFFSET_R}deg)`;
      pill.style.transition = 'none';
    });

    // Staggered entrance: each pill transitions to its natural position
    // Slow, smooth ease-out (not a spring) gives a premium, intentional feel.
    const ENTER_DURATION  = 1000;  // ms — snappy but not jarring
    const ENTER_EASING    = 'cubic-bezier(0.16, 1, 0.3, 1)'; // spring ease — matches site-wide feel
    const STAGGER         = 100;   // ms between each pill
    const START_DELAY     = 100;   // ms before the first pill moves
    const lastDelay       = START_DELAY + (pills.length - 1) * STAGGER;
    const totalDuration   = lastDelay + ENTER_DURATION + 200;

    pills.forEach((pill, i) => {
      const delay = START_DELAY + i * STAGGER;

      setTimeout(() => {
        pill.style.transition =
          `opacity 0.3s ${ENTER_EASING},
           transform ${ENTER_DURATION}ms ${ENTER_EASING}`;
        pill.style.opacity   = '1';
        pill.style.transform = '';
      }, delay);

      // Remove inline styles after animation settles so drag works unimpeded
      setTimeout(() => {
        pill.style.transition = '';
        pill.style.opacity    = '';
        pill.style.transform  = '';
      }, delay + ENTER_DURATION + 120);
    });

    // Restore the original clip-path once every pill has fully settled
    setTimeout(() => {
      strip.style.clipPath = '';
    }, totalDuration);
  }

  // ── Draggable portrait strip ────────────────────────────────────────────────
  // Uses the Pointer Events API so mouse and touch both work.
  // Momentum: on pointer-up, velocity decays at 94% per frame until < 0.4px/frame.
  function initPortraitDrag() {
    const strip = document.querySelector<HTMLElement>('.portrait-strip');
    const track = strip?.querySelector<HTMLElement>('.portrait-track');
    if (!strip || !track) return;

    let startX         = 0;
    let startTranslate = 0;
    let currentX       = 0;
    let isDragging     = false;
    let velocity       = 0;
    let lastX          = 0;
    let rafId: ReturnType<typeof requestAnimationFrame> | null = null;

    // +40 ensures 40px of empty space after the last pill at max drag
    const getMaxDrag = () => Math.max(0, track.scrollWidth - strip.clientWidth + 40);

    const apply = (x: number) => {
      currentX = Math.max(-getMaxDrag(), Math.min(0, x));
      track.style.transform = `translateX(${currentX}px)`;
    };

    const onDown = (e: PointerEvent) => {
      isDragging = true;
      startX = e.clientX;
      startTranslate = currentX;
      lastX = e.clientX;
      velocity = 0;
      strip.classList.add('is-dragging');
      strip.setPointerCapture(e.pointerId);
      if (rafId) { cancelAnimationFrame(rafId); rafId = null; }
    };

    const DRAG_FACTOR = 0.75; // < 1 slows the drag relative to pointer movement

    const onMove = (e: PointerEvent) => {
      if (!isDragging) return;
      velocity = (e.clientX - lastX) * DRAG_FACTOR;
      lastX = e.clientX;
      apply(startTranslate + (e.clientX - startX) * DRAG_FACTOR);
    };

    const onUp = () => {
      if (!isDragging) return;
      isDragging = false;
      strip.classList.remove('is-dragging');
      // Momentum coast
      const coast = () => {
        velocity *= 0.96;
        if (Math.abs(velocity) < 0.4) return;
        apply(currentX + velocity);
        rafId = requestAnimationFrame(coast);
      };
      rafId = requestAnimationFrame(coast);
    };

    strip.addEventListener('pointerdown',   onDown);
    strip.addEventListener('pointermove',   onMove);
    strip.addEventListener('pointerup',     onUp);
    strip.addEventListener('pointercancel', onUp);

    document.addEventListener('astro:before-swap', () => {
      strip.removeEventListener('pointerdown',   onDown);
      strip.removeEventListener('pointermove',   onMove);
      strip.removeEventListener('pointerup',     onUp);
      strip.removeEventListener('pointercancel', onUp);
      if (rafId) cancelAnimationFrame(rafId);
    }, { once: true });
  }

  function initAll() {
    initPortraitScatter();
    initPortraitDrag();
  }

  initAll();
  document.addEventListener('astro:after-swap', initAll);
</script>

<style>
  /* ── Main body text ─────────────────────────────────────────────────────── */
  .page-body {
    font-family: var(--font-uncut);
    font-size: 19px;
    font-weight: 400;
    line-height: 1.6;
    color: var(--color-orange-950);
    grid-column: 1 / 6;
    max-width: 68ch;
  }

  .page-body h2 {
    font-weight: 700;
    font-size: 13px;
    letter-spacing: 0.04em;
    color: var(--color-taupe-400);
    margin: 32px 0 8px;
  }

  .page-body p {
    margin: 0 0 16px;
    text-wrap: balance;
  }

  .page-body ul {
    list-style: disc;
    padding-left: 1rem;
  }

  .page-body ul li {
    margin-bottom: 1rem;
    text-wrap: balance;
  }

  .page-body a {
    color: var(--color-orange-500);
    text-decoration: none;
  }

  .page-body a:hover {
    text-decoration: underline;
  }

  /* ── Side column — wraps both Capabilities and Awards ───────────────────── */
  /*
   * On desktop: .page-sides sits in cols 8–9 of the .row grid.
   * It's a flex column so Capabilities and Awards stay pinned together
   * with exactly 40px between them, regardless of how tall .page-body is.
   * align-self: start prevents it from stretching to match the body height.
   */
  .page-sides {
    grid-column: 8 / -1;
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-self: start;
  }

  .page-side {
    font-family: var(--font-uncut);
    font-size: 15px;
    color: var(--color-taupe-500);
  }

  .page-side-title {
    color: var(--color-orange-950);
    margin-bottom: 15px;
  }

  .page-side ul li {
    margin-bottom: 10px;
  }

  /* ── Portrait strip ─────────────────────────────────────────────────────── */
  .portrait-strip {
    margin-top: 80px;
    margin-bottom: 40px;
    cursor: grab;
    user-select: none;
    -webkit-user-select: none;
    touch-action: none;

    /* Left edge aligns with body text; no left clip — pills slide freely
       into the sidebar area as you drag. Right clips at viewport edge.   */
    overflow: visible;
    clip-path: inset(0 0 0 -9999px);
    width: calc(100% + 40px);
  }

  .portrait-strip.is-dragging {
    cursor: grabbing;
  }

  .portrait-track {
    display: flex;
    gap: 20px;
    will-change: transform;
  }

  .portrait-pill {
    flex-shrink: 0;
    width: 210px;
    height: 280px;
    border-radius: 168px;
    background: var(--color-orange-500);
    overflow: hidden;
    position: relative;
  }

  .portrait-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    pointer-events: none;
    user-select: none;
    -webkit-user-select: none;
  }

  /* ── Mobile overrides ───────────────────────────────────────────────────── */
  @media (max-width: 1023px) {

    /* Body text: full width, scale down to 16px */
    .page-body {
      grid-column: 1 / -1;
      font-size: 16px;
    }

    /* Side columns: full width, two columns side-by-side */
    .page-sides {
      grid-column: 1 / -1;
      flex-direction: row;
      gap: 20px;
      align-items: flex-start;
    }

    .page-side {
      flex: 1;
      font-size: 14px;
    }

    /* Portrait strip: aligned with content on left, bleeds to viewport right edge */
    .portrait-strip {
      width: calc(100% + 20px); /* extends from content left edge to viewport right edge */
      clip-path: inset(0);
      margin-top: 80px;
    }

    .portrait-pill {
      width: 160px;
      height: 220px;
      border-radius: 999px;
    }

  }
</style>
