---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import Analytics from '../components/Analytics.astro';
import Cursor from '../components/Cursor.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Jeff Herrera — Creative Director',
  description = 'Jeff Herrera is a Creative Director based in NYC, crafting lasting brands across physical & digital.',
} = Astro.props;

const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <ViewTransitions />

    <!-- Open Graph / Social sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={`${Astro.url.origin}/images/SEO%20Image.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={`${Astro.url.origin}/images/SEO%20Image.png`} />

  </head>

  <body class="overflow-x-hidden">
    <div class="page-root">
      <div class="page-layout">
        <Sidebar currentPath={currentPath} />
        <slot />
      </div>
    </div>

    <Footer />

    <Cursor />
    <Analytics />
  </body>
</html>

<script>
  import Lenis from 'lenis';

  let lenis: Lenis | null = null;
  let lenisRaf: number | null = null;

  function initLenis() {
    lenis = new Lenis({
      duration: 1.2,
      easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
    });

    function raf(time: number) {
      lenis!.raf(time);
      lenisRaf = requestAnimationFrame(raf);
    }
    lenisRaf = requestAnimationFrame(raf);

    document.addEventListener('astro:before-swap', () => {
      if (lenisRaf !== null) cancelAnimationFrame(lenisRaf);
      lenis?.destroy();
      lenis = null;
      lenisRaf = null;
    }, { once: true });
  }

  initLenis();
  document.addEventListener('astro:after-swap', initLenis);

  // Allow other components to trigger a smooth scroll via Lenis
  document.addEventListener('scroll-to-top', () => {
    lenis?.scrollTo(0);
  });
</script>

<style>
  .page-root {
    background: var(--color-cream);
    min-height: 100vh;
  }

  .page-layout {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 20px;
    position: relative;
  }

  @media (max-width: 1023px) {
    .page-layout {
      grid-template-columns: 1fr;
      gap: 0;
      padding-top: 80px; /* 40px top padding + 40px button height */
    }
  }

</style>
