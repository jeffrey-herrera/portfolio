---

<main class="main-content" id="main-content" data-pagefind-body>
  <slot />
</main>

<style>
  /*
   * Right-column content wrapper for all pages.
   * flex-1 fills the remaining width after the 385px sidebar.
   * position: relative for child absolute elements (e.g. divider on home).
   */
  .main-content {
    grid-column: 4 / -1;
    margin-right: 40px;
    padding-bottom: 80px;
    position: relative;
    /* Subtle fade + rise on every page load / view-transition swap */
    animation: pageEnter 1.4s cubic-bezier(0.16, 1, 0.3, 1) both;
  }

  @keyframes pageEnter {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .main-content {
      animation: none;
    }
  }

  @media (max-width: 1023px) {
    .main-content {
      grid-column: 1 / -1;
      margin-right: 0;
      padding-left: 20px;
      padding-right: 20px;
      min-width: 0; /* prevent grid item from expanding beyond its 1fr track */
    }
  }
</style>
