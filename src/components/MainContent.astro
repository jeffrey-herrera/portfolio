---

<main class="main-content">
  <slot />
</main>

<style>
  /*
   * Right-column content wrapper for all pages.
   * flex-1 fills the remaining width after the 385px sidebar.
   * position: relative for child absolute elements (e.g. divider on home).
   */
  .main-content {
    grid-column: 4 / -1;
    margin-right: 40px;
    padding-bottom: 80px;
    position: relative;
  }

  @media (max-width: 1023px) {
    .main-content {
      grid-column: 1 / -1;
      margin-right: 0;
      padding-left: 20px;
      padding-right: 20px;
      min-width: 0; /* prevent grid item from expanding beyond its 1fr track */
    }
  }
</style>
