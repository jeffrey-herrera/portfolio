---
import Button from './Button.astro';
---
<footer class="site-footer">
  <video class="footer-bg-video" autoplay muted loop playsinline poster="/images/Footer_Static.png">
    <source src="/images/Footer_Video.mp4" type="video/mp4" />
  </video>
  <div class="footer-inner">

    <div class="footer-hero">
      <span class="footer-label">JEFF HERRERA</span>

      <div class="footer-text">
        <div class="footer-row">
          <span class="footer-word footer-word--serif">You</span>
          <span class="footer-word footer-word--serif">reached</span>
          <span class="footer-word footer-word--sans">THE</span>
          <span class="footer-word footer-word--sans">END,</span>
        </div>
        <div class="footer-row">
          <span class="footer-word footer-word--sans">LET'S</span>
          <span class="footer-word footer-word--sans">make</span>
          <span class="footer-word footer-word--sans">it</span>
          <span class="footer-word footer-word--serif">a</span>
          <span class="footer-word footer-word--serif">beginning.</span>
        </div>
      </div>

      <span class="footer-label">CREATIVE DIRECTOR</span>
    </div>

    <Button href="mailto:hello@jeffherrera.com" variant="primary-dark" class="footer-cta">
      →&nbsp; Let's Talk
    </Button>

  </div>
</footer>

<script>
  import { initMagnetic } from '../utils/magnetic.ts';
  import { track } from '@vercel/analytics';

  // ── Footer CTA analytics ──────────────────────────────────────────────────
  function initFooterAnalytics() {
    const cta = document.querySelector<HTMLAnchorElement>('.footer-cta');
    if (!cta) return;
    const onClick = () => { track('email_clicked'); };
    cta.addEventListener('click', onClick);
    document.addEventListener('astro:before-swap', () => {
      cta.removeEventListener('click', onClick);
    }, { once: true });
  }

  // ── Footer parallax + magnetic CTA ────────────────────────────────────────
  function initFooterEffects() {
    const reducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const footer = document.querySelector('.site-footer') as HTMLElement | null;
    const words   = footer?.querySelectorAll<HTMLElement>('.footer-word') ?? [];
    const cta     = footer?.querySelector<HTMLElement>('.footer-cta');

    if (!footer) return;

    if (!reducedMotion) {
      // ── Footer word parallax ──────────────────────────────────────────────
      // Each word drifts horizontally at a different rate as the footer scrolls
      // into view. Rate sign = direction; magnitude = speed relative to scroll.
      const wordRates = [0.14, -0.26, 0.20, -0.32, 0.10, -0.22, 0.28, -0.16, 0.24, -0.18];

      let ticking = false;
      const onScroll = () => {
        if (ticking) return;
        ticking = true;
        requestAnimationFrame(() => {
          const rect     = footer.getBoundingClientRect();
          const vh       = window.innerHeight;
          const progress = Math.max(0, Math.min(1, (vh - rect.top) / (vh + rect.height)));

          // Skip parallax on mobile — shifts would push words off the narrow screen
          if (window.innerWidth >= 1024) {
            words.forEach((word, i) => {
              const rate  = wordRates[i % wordRates.length];
              const shift = (progress - 0.5) * rate * 360;
              word.style.transform = `translateX(${shift}px)`;
            });
          } else {
            words.forEach(word => { word.style.transform = ''; });
          }

          ticking = false;
        });
      };

      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll();

      // ── Magnetic CTA ──────────────────────────────────────────────────────
      let cleanupMagnetic: (() => void) | null = null;
      if (cta) {
        cleanupMagnetic = initMagnetic(cta, { strength: 0.35, radiusMultiplier: 1.4 });
      }

      document.addEventListener('astro:before-swap', () => {
        window.removeEventListener('scroll', onScroll);
        cleanupMagnetic?.();
      }, { once: true });
    }
  }

  initFooterEffects();
  initFooterAnalytics();
  document.addEventListener('astro:after-swap', initFooterEffects);
  document.addEventListener('astro:after-swap', initFooterAnalytics);
</script>

<style>
  .site-footer {
    position: relative;
    /* Match the video's native 1360 × 656 aspect ratio so the video fills
       the full height without letterboxing at any viewport width */
    aspect-ratio: 85 / 41;
    width: 100%;
    overflow: hidden;
  }

  /* Full-bleed video — no overlay, video shows through completely */
  .footer-bg-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
    pointer-events: none;
  }

  .footer-inner {
    position: relative;
    z-index: 1;
    max-width: 1440px;
    margin: 0 auto;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 64px;
  }

  .footer-hero {
    display: flex;
    align-items: center;
    gap: 56px;
    padding: 0 40px;
    width: 100%;
  }

  .footer-label {
    flex-shrink: 0;
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 18px;
    text-transform: uppercase;
    color: var(--color-orange-500);
  }

  .footer-text {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 20.759px;
    text-transform: uppercase;
    color: var(--color-orange-50);
  }

  .footer-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
  }

  .footer-word {
    flex-shrink: 0;
    will-change: transform;
    transition: transform 0.05s linear;
  }

  .footer-word--sans {
    font-family: var(--font-sans);
    font-weight: 700;
    font-size: 57px;
    line-height: 1.15;
  }

  .footer-word--serif {
    font-family: var(--font-fragment);
    font-weight: 400;
    font-size: 52px;
    line-height: 1.15;
  }

  /* Magnetic effect needs will-change + transform transition on top of Button base styles */
  :global(.footer-cta) {
    will-change: transform;
    transition: background 0.15s, color 0.15s, transform 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94) !important;
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-word { transition: none; }
    :global(.footer-cta) { transition: none !important; }
  }

  /* ── Mobile ───────────────────────────────────────────────────────────── */
  @media (max-width: 1023px) {

    /* Portrait crop: video fills height, sides crop so the center flower shows large */
    .site-footer {
      aspect-ratio: 3 / 4;
    }

    /* Stack everything centered: label → words → label */
    .footer-hero {
      flex-direction: column;
      align-items: center;
      gap: 20px;
      text-align: center;
      padding: 0 20px;
      position: relative;
    }

    /* Soft orange glow centered behind the display text */
    .footer-hero::before {
      content: '';
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      width: 220px;
      height: 220px;
      border-radius: 50%;
      background: var(--color-orange-500);
      opacity: 0.75;
      filter: blur(30px);
      pointer-events: none;
    }

    .footer-text {
      width: 100%;
      gap: 0; /* collapse row gap so all four lines read as one text block */
    }

    /* Centered word rows — wrapping enabled for the line-break technique below */
    .footer-row {
      justify-content: center;
      flex-wrap: wrap;
      gap: 0 0.5em;
    }

    /* Bump the middle display text up — labels stay at their 18px */
    .footer-word--sans {
      font-size: clamp(2rem, 9vw, 57px);
      letter-spacing: -0.04em;
    }

    .footer-word--serif {
      font-size: clamp(1.75rem, 8vw, 52px);
    }

    /*
     * Split row 1 into two visual lines using flex ordering:
     *   Line A: "You reached"   (words 1–2, order 0)
     *   Line B: "THE END,"      (words 3–4, order 2)
     * The ::after pseudo-element (order 1, flex-basis 100%) acts as an invisible
     * line-break between the two groups.
     */
    .footer-row:first-child .footer-word:nth-child(3),
    .footer-row:first-child .footer-word:nth-child(4) {
      order: 2;
    }
    .footer-row:first-child::after {
      content: '';
      flex-basis: 100%;
      height: 0;
      order: 1;
    }

    /*
     * Split row 2 into two visual lines:
     *   Line A: "LET'S make it"   (words 1–3, order 0)
     *   Line B: "a beginning."    (words 4–5, order 2)
     */
    .footer-row:last-child .footer-word:nth-child(4),
    .footer-row:last-child .footer-word:nth-child(5) {
      order: 2;
    }
    .footer-row:last-child::after {
      content: '';
      flex-basis: 100%;
      height: 0;
      order: 1;
    }

    /* Labels dark on mobile — readable against the lighter flower background */
    .footer-label {
      color: var(--color-orange-50);
    }

    /* Tighten the gap between hero text and CTA */
    .footer-inner {
      gap: 32px;
    }

  }
</style>
