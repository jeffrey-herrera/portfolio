---
// Custom cursor — site-wide, pointer devices only.
// Usage: add data-cursor-label="View" to any <a> or <button>.
// Add data-cursor-type="drag" to any draggable element.
// If data-cursor-label is absent on a hovered link, the ring appears instead.
---

<div id="cursor" aria-hidden="true">
  <!-- Pill: dot always present; expands to contain label when active -->
  <div id="cursor-pill">
    <div id="cursor-dot"></div>
    <span id="cursor-label"></span>
  </div>
  <!-- Drag cursor -->
