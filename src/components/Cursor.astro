<!-- Hide system cursor on pointer devices globally -->
<style is:global>
  @media (hover: hover) and (pointer: fine) {
    *, *::before, *::after {
      cursor: none !important;
    }
  }
</style>

<style>
  #cursor {
    position: fixed;
    top: 0;
    left: 0;
    pointer-events: none;
    z-index: 9999;
    will-change: transform;
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  #cursor.is-visible {
    opacity: 1;
  }

  /* ── Pill ─────────────────────────────────────────────────────────────
     Default: zero padding, transparent — visually just the dot.
     Active:  orange-500 bg + padding expands it into a capsule.          */
  #cursor-pill {
    display: flex;
    align-items: center;
    border-radius: 999px;
    background: transparent;
    padding: 0;
    transition:
      background 0.2s ease,
      padding    0.2s cubic-bezier(0.4, 0, 0.2, 1);
  }

  #cursor.has-label #cursor-pill {
    background: var(--color-orange-500);
    padding: 4px 12px 4px 6px;
  }

  /* Hide pill when drag cursor is active */
  #cursor.is-drag #cursor-pill {
    display: none;
  }

  /* ── Dot ──────────────────────────────────────────────────────────── */
  #cursor-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--color-orange-500);
    border: 1.5px solid transparent;
    flex-shrink: 0;
    transition:
      transform    0.15s cubic-bezier(0.25, 0.46, 0.45, 0.94),
      background   0.15s ease,
      border-color 0.15s ease;
  }

  /* Grow to ~20px hollow ring on hover — links without a label */
  /* scale(1.667) = 20px from 12px base; scale(1.333) = 16px from 12px base */
  #cursor.is-hovering:not(.has-label):not(.is-drag) #cursor-dot {
    background: transparent;
    border-color: var(--color-orange-500);
    animation: cursor-pulse 1.6s ease-in-out infinite;
  }

  @keyframes cursor-pulse {
    0%   { transform: scale(1.667); }
    50%  { transform: scale(1.333); }
    100% { transform: scale(1.667); }
  }

  /* Dot color flips to cream when pill is active (orange bg) */
  #cursor.has-label #cursor-dot {
    background: var(--color-orange-50);
  }

  /* ── Mobile menu override ──────────────────────────────────────────────
     When the orange overlay is open, flip cursor + hover ring to orange-50
     so they remain visible against the orange-500 background.              */
  :global(html.menu-open #cursor-dot) {
    background: var(--color-orange-50);
  }

  :global(html.menu-open #cursor.is-hovering:not(.has-label):not(.is-drag) #cursor-dot) {
    background: transparent;
    border-color: var(--color-orange-50) !important;
  }

  @media (prefers-reduced-motion: reduce) {
    #cursor-pill,
    #cursor-dot,
    #cursor-label,
    #cursor-drag {
      transition: none;
    }

    #cursor.is-hovering:not(.has-label):not(.is-drag) #cursor-dot {
      animation: none;
      transform: scale(1.667);
    }
  }

  /* ── Label ────────────────────────────────────────────────────────────
     Reveals left-to-right via max-width expansion + opacity fade.        */
  #cursor-label {
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-orange-50);
    white-space: nowrap;
    /* Collapsed by default */
    max-width: 0;
    overflow: hidden;
    opacity: 0;
    margin-left: 0;
    transition:
      max-width   0.22s cubic-bezier(0.4, 0, 0.2, 1),
      opacity     0.18s ease,
      margin-left 0.2s  cubic-bezier(0.4, 0, 0.2, 1);
  }

  #cursor.has-label #cursor-label {
    max-width: 240px; /* generous cap; text never gets close */
    opacity: 1;
    margin-left: 8px;
  }

  /* ── Drag cursor ──────────────────────────────────────────────────────
     Rendered at 80×88px (31×34 scaled up). HALF=6 (cursor dot radius).
     Offsets = HALF − (renderedW/2), HALF − (renderedH/2):
     x = 6 − 40 = −34px,  y = 6 − 44 = −38px                           */
  #cursor-drag {
    position: absolute;
    left: -34px;
    top: -38px;
    opacity: 0;
    transition: opacity 0.12s ease;
    pointer-events: none;
  }


  #cursor.is-drag #cursor-drag {
    opacity: 1;
  }
</style>

<script>
  // Module-level position — persists across view transitions so cursor
  // never jumps back to (0,0) after a navigation or click.
  let savedX = -200;
  let savedY = -200;
  let hasMoved = false;

  function initCursor() {
    if (!window.matchMedia('(hover: hover) and (pointer: fine)').matches) return;

    const cursor = document.getElementById('cursor')       as HTMLElement | null;
    const label  = document.getElementById('cursor-label') as HTMLElement | null;
    if (!cursor || !label) return;

    const LERP = 0.35;
    const HALF = 6;
    let mouseX = savedX, mouseY = savedY;
    let cursorX = savedX, cursorY = savedY;
    let rafId: ReturnType<typeof requestAnimationFrame>;

    // ── Reveal: immediately if we already have a position, else wait ─────
    if (hasMoved) {
      cursor.classList.add('is-visible');
    } else {
      const onFirstMove = () => {
        cursor.classList.add('is-visible');
        document.removeEventListener('mousemove', onFirstMove);
      };
      document.addEventListener('mousemove', onFirstMove);
    }

    // ── Raw pointer tracking ─────────────────────────────────────────────
    const onMouseMove = (e: MouseEvent) => {
      mouseX = e.clientX;
      mouseY = e.clientY;
      savedX = mouseX;
      savedY = mouseY;
      hasMoved = true;
    };
    document.addEventListener('mousemove', onMouseMove);

    // ── Hide / show when pointer leaves / enters the viewport ────────────
    const onDocLeave  = () => cursor.classList.remove('is-visible');
    const onDocEnter  = () => cursor.classList.add('is-visible');
    document.addEventListener('mouseleave', onDocLeave);
    document.addEventListener('mouseenter', onDocEnter);

    // ── Hover state ──────────────────────────────────────────────────────
    const onMouseOver = (e: MouseEvent) => {
      const target = (e.target as Element).closest<HTMLElement>(
        'a, button, [role="button"], [data-cursor-type]'
      );

      if (target) {
        cursor.classList.add('is-hovering');
        const cursorType = target.dataset.cursorType;
        const text = target.dataset.cursorLabel;

        if (cursorType === 'drag') {
          cursor.classList.add('is-drag');
          cursor.classList.remove('has-label');
          label.textContent = '';
        } else if (text) {
          cursor.classList.remove('is-drag');
          label.textContent = text;
          cursor.classList.add('has-label');
        } else {
          cursor.classList.remove('is-drag', 'has-label');
          label.textContent = '';
        }
      } else {
        cursor.classList.remove('is-hovering', 'has-label', 'is-drag');
        label.textContent = '';
      }
    };
    document.addEventListener('mouseover', onMouseOver);

    // ── Lerp animation loop ──────────────────────────────────────────────
    const tick = () => {
      cursorX += (mouseX - cursorX) * LERP;
      cursorY += (mouseY - cursorY) * LERP;
      cursor.style.transform =
        `translate3d(${cursorX - HALF}px, ${cursorY - HALF}px, 0)`;
      rafId = requestAnimationFrame(tick);
    };
    rafId = requestAnimationFrame(tick);

    // ── Cleanup before View Transition swap ──────────────────────────────
    document.addEventListener('astro:before-swap', () => {
      cancelAnimationFrame(rafId);
      cursor.classList.remove('is-hovering', 'has-label', 'is-drag');
      label.textContent = '';
      document.removeEventListener('mousemove',  onMouseMove);
      document.removeEventListener('mouseover',  onMouseOver);
      document.removeEventListener('mouseleave', onDocLeave);
      document.removeEventListener('mouseenter', onDocEnter);
    }, { once: true });
  }

  initCursor();
  document.addEventListener('astro:after-swap', initCursor);
</script>
