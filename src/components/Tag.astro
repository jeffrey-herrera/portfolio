---
interface Props {
  label: string;
}

const { label } = Astro.props;
---

<span class="tag">{label}</span>

<style>
  .tag {
    font-family: var(--font-sans);
    font-size: 11px;
    color: var(--color-taupe-400);
    background: var(--color-cream);
    padding: 4px 10px;
    border-radius: 999px;
    white-space: nowrap;
  }
</style>
