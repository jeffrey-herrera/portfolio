---
import Logo from './Logo.astro';

interface Props {
  currentPath?: string;
}

const { currentPath = '/' } = Astro.props;

const navItems = [
  { href: '/', label: 'Work' },
  { href: '/about', label: 'About' },
  { href: '/thoughts', label: 'Thoughts' },
  { href: '/playlists', label: 'Playlists' },
];

const socialLinks = [
  { href: 'https://instagram.com/_isthatjeff', label: 'Instagram', external: true },
  { href: 'https://linkedin.com/in/jeffrey-herrera', label: 'LinkedIn', external: true },
  { label: 'Email', copyEmail: true },
];

const isHome      = currentPath === '/';
const isAbout     = currentPath === '/about';
const isPlaylists = currentPath === '/playlists';

// Years present in the playlists data — used for sidebar nav
import { playlists } from '../data/playlists.ts';
const playlistYears = isPlaylists
  ? [...new Set(playlists.map(p => p.year))].sort((a, b) => b - a)
  : [];
---

<!-- ─── Desktop sidebar ────────────────────────────────────────────────────── -->
<aside class="sidebar">

  <div class="sidebar-sticky">

  <!-- Logo -->
  <div class="sidebar-item">
    <a href="/" class="favicon-link" aria-label="Home">
      <Logo />
    </a>
  </div>

  <!-- Navigation -->
  <nav class="sidebar-item">
    <ul class="nav-list">
      {navItems.map((item) => (
        <li>
          <a
            href={item.href}
            class={`nav-link ${currentPath === item.href ? 'nav-link--active' : ''}`}
          >
            {item.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- Social links -->
  <div class="sidebar-item">
    <div class="sidebar-section">
      <span class="sidebar-label">Let's Talk</span>
      <div class="sidebar-links">
        {socialLinks.map((link) => (
          link.copyEmail ? (
            <button class="sidebar-link js-copy-email" data-cursor-label="Copy email" type="button">
              {link.label}
            </button>
          ) : (
            <a
              href={link.href}
              class="sidebar-link"
              {...(link.external ? { target: '_blank', rel: 'noopener' } : {})}
            >{link.label}</a>
          )
        ))}
      </div>
    </div>
  </div>

{isPlaylists && (
    <div class="sidebar-item sidebar-year-nav" id="sidebar-year-nav">
      <div class="sidebar-section">
        <span class="sidebar-label">Years</span>
        <div class="sidebar-links">
          {playlistYears.map(year => (
            <a href={`#year-${year}`} class="sidebar-link sidebar-year-link" data-year={year}>
              {year}
            </a>
          ))}
        </div>
      </div>
    </div>
  )}

  {isHome && (
    <!-- Selected Work sub-nav: starts hidden, fades in when user scrolls into the work section -->
    <div class="sidebar-item sidebar-work-nav">
      <div class="sidebar-section">
        <span class="sidebar-label">Selected Work</span>
        <div class="sidebar-links">
          <a href="/#brand" class="sidebar-link">Brand</a>
          <a href="/#physical" class="sidebar-link">Physical</a>
          <a href="/#digital" class="sidebar-link">Digital</a>
        </div>
      </div>
    </div>
  )}

  {isHome && (
    <!-- Back to top: starts hidden, fades in at 40% scroll depth -->
    <div class="sidebar-item sidebar-back-top" id="sidebar-back-top">
      <button class="back-to-top-btn" id="back-to-top-btn" type="button">
        Back to top <span>↑</span>
      </button>
    </div>
  )}

  </div>

</aside>


<!-- ─── Mobile header bar (fixed, always visible on mobile) ───────────────── -->
<div class="mobile-header" id="mobile-header">
  <a href="/" class="favicon-link" aria-label="Home">
    <Logo />
  </a>

  <button class="menu-btn" id="menu-btn" aria-label="Open menu" aria-expanded="false">
    <!-- Hamburger -->
    <svg class="icon-hamburger" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <line x1="3" y1="7" x2="21" y2="7" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
      <line x1="3" y1="17" x2="21" y2="17" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
    </svg>
    <!-- Close / X -->
    <svg class="icon-close" width="24" height="24" viewBox="0 0 24 24" fill="none" aria-hidden="true">
      <line x1="5" y1="5" x2="19" y2="19" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
      <line x1="19" y1="5" x2="5" y2="19" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
    </svg>
  </button>
</div>




<style>

  /* ─── Desktop sidebar ──────────────────────────────────────────────────── */
  .sidebar {
    grid-column: 1/3;
    align-self: stretch;
    position: relative;
    z-index: 1;
  }

  .sidebar-sticky {
    padding-top: 40px;
    padding-left: 40px;
    padding-bottom: 40px;
  }

  @media (max-width: 1023px) {
    .sidebar { display: none; }
  }

  .sidebar-item {
    margin-bottom: 40px;
  }

  .current {
    background-color: #fff;
    padding: 10px 20px;
    border-radius: 9999px;
    display: flex;
    flex-direction: column;
    white-space: nowrap;
    margin-left: -20px;
  }

  .current span {
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .favicon-link {
    display: block;
    width: 32px;
    height: 32px;
  }

  .nav-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 8px;
    line-height: 1.35;
  }

  /* The dot lives entirely on the link via ::before — no separate element needed */
  .nav-link {
    display: inline-block;
    position: relative;
    font-family: var(--font-sans);
    font-size: 16px;
    font-weight: 500;
    color: var(--color-orange-950);
    text-decoration: none;
    transition: color 0.15s;
  }

  .nav-link--active { color: var(--color-orange-500); }
  .nav-link:hover { color: var(--color-orange-500); }

  /* Orange indicator dot — attached to the active link, 10px to the left of the text */
  .nav-link--active::before {
    content: '';
    position: absolute;
    left: -10px;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--color-orange-500);
  }

  .sidebar-section {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding-top: 40px;
  }

  .sidebar-label {
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 500;
    color: var(--color-taupe-400);
    line-height: 1.15;
    white-space: nowrap;
  }

  .sidebar-links {
    display: flex;
    gap: 8px;
    flex-direction: column;
    align-items: flex-start;
    font-family: var(--font-sans);
    font-size: 15px;
    font-weight: 500;
    color: var(--color-orange-950);
    line-height: 1.5;
  }

  .sidebar-link {
    color: var(--color-orange-950);
    text-decoration: none;
    transition: color 0.15s;
  }

  button.sidebar-link {
    background: none;
    border: none;
    padding: 0;
    font-family: inherit;
    font-size: inherit;
    font-weight: inherit;
    line-height: inherit;
    cursor: pointer;
    text-align: left;
  }

  .sidebar-link:hover    { color: var(--color-orange-500); }
  .sidebar-link.is-active { color: var(--color-orange-500); }

  .sidebar-link--cta {
    display: inline-flex;
    align-items: center;
    gap: 4px;
  }

  /* Year nav: always visible on /playlists, active link tracks scroll */
  .sidebar-year-link.is-active { color: var(--color-orange-500); }

  /* Selected Work sub-nav: hidden by default, JS adds .visible on scroll */
  .sidebar-work-nav {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
  }

  .sidebar-work-nav.visible {
    opacity: 1;
    pointer-events: auto;
  }

  /* Back to top button */
  .sidebar-back-top {
    position: fixed;
    bottom: 40px;
    left: 40px;
    margin: 0;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.4s ease;
    z-index: 500;
  }

  .sidebar-back-top.visible {
    opacity: 1;
    pointer-events: auto;
  }

  .back-to-top-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    border: 1px solid var(--color-taupe-400);
    border-radius: 999px;
    padding: 12px 20px;
    font-family: var(--font-sans);
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 1%;
    color: var(--color-taupe-400);
    background: transparent;
    cursor: pointer;
    will-change: transform;
    transition: border-color 0.15s, color 0.15s, transform 0.25s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .back-to-top-btn:hover {
    border-color: var(--color-orange-500);
    color: var(--color-orange-500);
  }


  /* ─── Mobile header bar ────────────────────────────────────────────────── */
  .mobile-header {
    display: none; /* desktop: hidden */
  }

  @media (max-width: 1023px) {
    .mobile-header {
      display: flex;
      position: sticky;
      top: 0;
      grid-column: 1 / -1;
      align-items: center;
      justify-content: space-between;
      padding: 20px;
      z-index: 200;
      background: var(--color-cream);
      /* Inherit rounded corners from page-layer when menu is open */
      border-radius: inherit;
    }
  }


  /* ─── Menu toggle button ───────────────────────────────────────────────── */
  .menu-btn {
    display: none;
  }

  @media (max-width: 1023px) {
    .menu-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 40px;
      background: none;
      border: none;
      cursor: pointer;
      color: var(--color-orange-950);
      padding: 0;
      z-index: 201; /* stays above overlay */
      transition: color 0.3s ease;
    }

    .mobile-header.menu-is-open .menu-btn {
      color: var(--color-orange-50);
    }

    /* Icon swap */
    .icon-close { display: none; }

    .menu-btn[aria-expanded="true"] .icon-hamburger { display: none; }
    .menu-btn[aria-expanded="true"] .icon-close     { display: block; }
  }



</style>


<script>
  // ─── Back to top ──────────────────────────────────────────────────────────
  function initBackToTop() {
    const btn = document.getElementById('back-to-top-btn');
    if (!btn) return;

    const onClick = () => {
      document.dispatchEvent(new CustomEvent('scroll-to-top'));
    };

    btn.addEventListener('click', onClick);
    document.addEventListener('astro:before-swap', () => {
      btn.removeEventListener('click', onClick);
    }, { once: true });
  }

  // ─── Mobile push nav ─────────────────────────────────────────────────────
  function initMobileMenu() {
    const menuBtn   = document.getElementById('menu-btn')     as HTMLButtonElement | null;
    const pushNav   = document.getElementById('push-nav')     as HTMLElement | null;
    const pageLayer = document.getElementById('page-layer')   as HTMLElement | null;
    const overlay   = document.getElementById('page-overlay') as HTMLElement | null;

    if (!menuBtn || !pushNav || !pageLayer) return;

    // Measure nav height so the page slides exactly far enough
    function setNavHeight() {
      pageLayer!.style.setProperty('--nav-height', pushNav!.scrollHeight + 'px');
    }

    setNavHeight();
    window.addEventListener('resize', setNavHeight);

    // Prevent keyboard access to hidden nav
    pushNav.setAttribute('inert', '');

    const openMenu = () => {
      setNavHeight();
      pageLayer.classList.add('is-open');
      pushNav.classList.add('is-open');
      pushNav.removeAttribute('inert');
      menuBtn.setAttribute('aria-expanded', 'true');
      menuBtn.setAttribute('aria-label', 'Close menu');
      pushNav.setAttribute('aria-hidden', 'false');
      document.documentElement.classList.add('menu-open');
    };

    const closeMenu = () => {
      pageLayer.classList.remove('is-open');
      pushNav.classList.remove('is-open');
      pushNav.setAttribute('inert', '');
      menuBtn.setAttribute('aria-expanded', 'false');
      menuBtn.setAttribute('aria-label', 'Open menu');
      pushNav.setAttribute('aria-hidden', 'true');
      document.documentElement.classList.remove('menu-open');
    };

    const onBtnClick = () => {
      menuBtn.getAttribute('aria-expanded') === 'true' ? closeMenu() : openMenu();
    };

    const onKeyDown = (e: KeyboardEvent) => {
      if (e.key === 'Escape' && menuBtn.getAttribute('aria-expanded') === 'true') {
        closeMenu();
        menuBtn.focus();
      }
    };

    menuBtn.addEventListener('click', onBtnClick);
    overlay?.addEventListener('click', closeMenu);
    document.addEventListener('keydown', onKeyDown);

    const cleanup = () => {
      closeMenu();
      window.removeEventListener('resize', setNavHeight);
      menuBtn.removeEventListener('click', onBtnClick);
      document.removeEventListener('keydown', onKeyDown);
    };

    document.addEventListener('astro:before-swap', cleanup, { once: true });
  }

  // ─── Selected Work nav smooth scroll ──────────────────────────────────────
  function initWorkNav() {
    const links = document.querySelectorAll<HTMLAnchorElement>('.sidebar-work-nav .sidebar-link');
    if (!links.length) return;

    links.forEach(link => {
      link.addEventListener('click', e => {
        // Only intercept if we're already on the home page
        const hash = link.getAttribute('href')?.split('#')[1];
        if (!hash) return;
        const target = document.getElementById(hash);
        if (!target) return;
        e.preventDefault();
        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });
  }

  // ─── Playlist year nav scroll tracking ────────────────────────────────────
  function initYearNav() {
    const links = document.querySelectorAll<HTMLAnchorElement>('.sidebar-year-link');
    if (!links.length) return;

    // Smooth-scroll via Lenis on anchor click
    links.forEach(link => {
      link.addEventListener('click', e => {
        e.preventDefault();
        const targetId = link.getAttribute('href')?.slice(1);
        const target   = targetId ? document.getElementById(targetId) : null;
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    });

    // Track which year section is in view
    const sections = Array.from(links)
      .map(link => {
        const id = link.getAttribute('href')?.slice(1);
        return id ? document.getElementById(id) : null;
      })
      .filter(Boolean) as HTMLElement[];

    const setActive = () => {
      const scrollY = window.scrollY + 160; // offset for sticky header
      let active: string | null = null;

      sections.forEach(section => {
        if (section.offsetTop <= scrollY) active = section.id;
      });

      links.forEach(link => {
        const matches = active && link.getAttribute('href') === `#${active}`;
        link.classList.toggle('is-active', !!matches);
      });
    };

    window.addEventListener('scroll', setActive, { passive: true });
    setActive();

    document.addEventListener('astro:before-swap', () => {
      window.removeEventListener('scroll', setActive);
    }, { once: true });
  }

  // ─── Copy email ───────────────────────────────────────────────────────────
  function initCopyEmail() {
    document.querySelectorAll<HTMLButtonElement>('.js-copy-email').forEach(btn => {
      btn.addEventListener('click', () => {
        navigator.clipboard.writeText('hello@jeffherrera.com').then(() => {
          const prev = btn.textContent!.trim();
          btn.textContent = 'Copied!';
          if (btn.dataset.cursorLabel) btn.dataset.cursorLabel = 'Copied!';
          setTimeout(() => {
            btn.textContent = prev;
            if (btn.dataset.cursorLabel) btn.dataset.cursorLabel = 'Copy email';
          }, 2000);
        });
      });
    });
  }

  // ─── Init ─────────────────────────────────────────────────────────────────
  function initAll() {
    initBackToTop();
    initMobileMenu();
    initWorkNav();
    initYearNav();
    initCopyEmail();
  }

  initAll();
  document.addEventListener('astro:after-swap', initAll);
</script>
